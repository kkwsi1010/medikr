---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = '식약처 공식 데이터 기반 의약품 정보 검색', ogImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Analytics & Ads — env vars 가 없으면 코드가 삽입되지 않음 (placeholder pattern)
const GA4_ID = import.meta.env.PUBLIC_GA4_ID as string | undefined;
const ADSENSE_CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT as string | undefined;
const NAVER_SITE_VERIFY = import.meta.env.PUBLIC_NAVER_VERIFY as string | undefined;
const GOOGLE_SITE_VERIFY = import.meta.env.PUBLIC_GOOGLE_VERIFY as string | undefined;
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | medikr — 의약품 정보</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="medikr" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary" />
  <link rel="canonical" href={canonical} />

  {GOOGLE_SITE_VERIFY && <meta name="google-site-verification" content={GOOGLE_SITE_VERIFY} />}
  {NAVER_SITE_VERIFY && <meta name="naver-site-verification" content={NAVER_SITE_VERIFY} />}

  {GA4_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
      <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_ID}');`}></script>
    </>
  )}

  {ADSENSE_CLIENT && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
      crossorigin="anonymous"
    ></script>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'medikr',
    url: 'https://medikr.kr/',
    description: '식약처 공식 데이터 기반 의약품 정보 검색',
    inLanguage: 'ko-KR',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: 'https://medikr.kr/search?q={q}' },
      'query-input': 'required name=q',
    },
    publisher: {
      '@type': 'Organization',
      name: 'medikr',
      url: 'https://medikr.kr/',
    },
  })}></script>

  <style is:global>
    :root { color-scheme: light; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Pretendard", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      color: #222;
      background: #fafafa;
    }
    header {
      background: #fff;
      border-bottom: 1px solid #e5e5e5;
      padding: 12px 16px;
    }
    header h1 { margin: 0; font-size: 20px; }
    header h1 a { color: #2563eb; text-decoration: none; }
    header p { margin: 4px 0 0; font-size: 13px; color: #666; }
    main { max-width: 880px; margin: 0 auto; padding: 16px; }
    main h2 { font-size: 24px; margin: 16px 0 8px; }
    main h3 { font-size: 17px; margin: 20px 0 6px; border-bottom: 1px solid #ddd; padding-bottom: 4px; }
    main img { max-width: 220px; height: auto; border: 1px solid #ddd; border-radius: 6px; margin: 8px 0; }
    main dl { display: grid; grid-template-columns: 120px 1fr; gap: 4px 12px; margin: 8px 0; }
    main dt { font-weight: 600; color: #555; }
    main p { white-space: pre-wrap; }
    main ul { padding-left: 20px; }
    main section { background: #fff; padding: 12px 16px; border-radius: 6px; margin-bottom: 12px; border: 1px solid #eee; }
    footer {
      text-align: center;
      padding: 24px 16px;
      color: #777;
      font-size: 13px;
      border-top: 1px solid #e5e5e5;
      background: #fff;
    }
    footer p { margin: 4px 0; }
  </style>
</head>
<body>
  <header>
    <h1><a href="/">medikr</a></h1>
    <p>식약처 공식 의약품 정보 검색</p>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>출처: 식품의약품안전처 공공데이터 (e약은요·DUR·낱알식별·허가정보)</p>
    <p>정보 제공 목적이며, 복용 전 반드시 의사·약사와 상의하십시오.</p>
    <p style="margin-top:10px">
      <a href="/about" style="color:#666;margin:0 8px">운영자</a>·
      <a href="/privacy" style="color:#666;margin:0 8px">개인정보처리방침</a>·
      <a href="/terms" style="color:#666;margin:0 8px">이용약관</a>·
      <a href="/rss.xml" style="color:#666;margin:0 8px">RSS</a>
    </p>
    <p>© 2026 medikr.kr</p>
  </footer>
</body>
</html>
