---
// AdSense 광고 슬롯 컴포넌트 — env(PUBLIC_ADSENSE_CLIENT) 와 slot id 가 있을 때만 노출
interface Props {
  slot: string;        // ad slot id (AdSense 발급)
  format?: string;     // 'auto' | 'fluid' | 'rectangle' etc
  fullWidth?: boolean;
}
const { slot, format = 'auto', fullWidth = true } = Astro.props;
const CLIENT = import.meta.env.PUBLIC_ADSENSE_CLIENT as string | undefined;
---
{CLIENT && slot && (
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={CLIENT}
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive={fullWidth ? 'true' : 'false'}
  ></ins>
  <script set:html={`(adsbygoogle = window.adsbygoogle || []).push({});`}></script>
)}

<style is:global>
  /* AdSense 가 unfilled (광고 없음 / 미승인) 응답 시 슬롯 제거 — 빈 공간 방지 */
  ins.adsbygoogle[data-ad-status="unfilled"] { display: none !important; }
  /* 광고 채워진 슬롯만 위/아래 spacing */
  ins.adsbygoogle[data-ad-status="filled"] { margin: 16px 0; }
</style>
