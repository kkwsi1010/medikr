---
import Layout from '../../layouts/Layout.astro';
import { listEasyDrugs, type EasyDrug } from '../../lib/mfds';
import { SYMPTOMS, type Symptom } from '../../lib/symptoms';

export async function getStaticPaths() {
  const { SYMPTOMS } = await import('../../lib/symptoms');
  const { listEasyDrugs } = await import('../../lib/mfds');

  // W1 라이브: 1,000 약. W5 에서 전체 확장.
  const ALL: EasyDrug[] = [];
  for (let p = 1; p <= 10; p++) {
    const { items, totalCount } = await listEasyDrugs(p, 100);
    ALL.push(...items);
    if (items.length < 100 || p * 100 >= totalCount) break;
  }
  return SYMPTOMS.map((s) => {
    const matches = ALL.filter((d) =>
      s.keywords.some((k) => (d.efcyQesitm ?? '').includes(k))
    ).slice(0, 100);
    return {
      params: { symptom: s.slug },
      props: { symptom: s, drugs: matches },
    };
  });
}

interface Props {
  symptom: Symptom;
  drugs: EasyDrug[];
}
const { symptom, drugs } = Astro.props;
---
<Layout
  title={`${symptom.label}에 쓰는 약`}
  description={`${symptom.label} 증상에 사용되는 의약품 ${drugs.length}종 — 식약처 공식 데이터`}
>
  <h2>{symptom.label} 증상에 쓰는 약</h2>
  <p style="color:#666">총 <strong>{drugs.length}</strong>개 의약품. 효능에 "{symptom.keywords.join(', ')}" 키워드가 포함된 약을 모았습니다.</p>
  <p style="color:#888;font-size:13px">⚠️ 본 목록은 정보 제공용이며, 실제 복용은 의사·약사 상담 후 결정하십시오.</p>

  {drugs.length === 0 ? (
    <p style="color:#888;font-style:italic">데이터가 아직 빌드되지 않았습니다. (MFDS_API_KEY 환경변수 설정 후 재배포 시 노출)</p>
  ) : (
    <ul>
      {drugs.map((d) => (
        <li style="margin:4px 0">
          <a href={`/약/${d.itemSeq}`}>{d.itemName}</a>
          {d.entpName && <span style="color:#666;font-size:13px"> — {d.entpName}</span>}
        </li>
      ))}
    </ul>
  )}
</Layout>
