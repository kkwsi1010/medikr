---
import Layout from '../../layouts/Layout.astro';

const SYMPTOMS = [
  { slug: 'gamgi', label: '감기' },
  { slug: 'duto', label: '두통' },
  { slug: 'wijang', label: '소화·위장' },
  { slug: 'baltyeol', label: '발열·해열' },
  { slug: 'tongjeung', label: '통증' },
  { slug: 'almreugi', label: '알레르기' },
  { slug: 'byunbi', label: '변비' },
  { slug: 'seolssa', label: '설사' },
  { slug: 'sumyeon', label: '수면' },
  { slug: 'pibu', label: '피부' },
];
---
<Layout title="증상별 약 찾기" description="감기·두통·위장 등 증상별로 의약품 검색">
  <h2>증상별 약 찾기</h2>
  <p>증상에 사용되는 의약품을 분류했습니다. 식약처 e약은요 효능 데이터 기반.</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;margin-top:16px">
    {SYMPTOMS.map((s) => (
      <a
        href={`/증상/${s.slug}`}
        style="display:block;padding:14px;background:#fff;border:1px solid #ddd;border-radius:6px;text-align:center;text-decoration:none;color:#222;font-weight:500"
      >{s.label}</a>
    ))}
  </div>
</Layout>
