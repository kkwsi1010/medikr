---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import FreshBadge from '../components/FreshBadge.astro';
import TrustBox from '../components/TrustBox.astro';
import { prefetchAll } from '../lib/mfds';

const { drugs, permitMap, pillMap } = await prefetchAll();
const recent = [...drugs]
  .map((d) => ({ d, date: permitMap.get(d.itemSeq)?.ITEM_PERMIT_DATE ?? '' }))
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''))
  .slice(0, 12)
  .map((x) => ({ ...x.d, _date: x.date }));

function fmtDate(d: string): string {
  if (!d || d.length !== 8) return '';
  return `${d.slice(0, 4)}.${d.slice(4, 6)}.${d.slice(6, 8)}`;
}
function relativeDate(d: string): string {
  if (!d || d.length !== 8) return '';
  const date = new Date(Number(d.slice(0, 4)), Number(d.slice(4, 6)) - 1, Number(d.slice(6, 8)));
  const diffMs = Date.now() - date.getTime();
  const days = Math.floor(diffMs / 86_400_000);
  if (days < 0) return '예정';
  if (days === 0) return '오늘';
  if (days === 1) return '어제';
  if (days < 7) return `${days}일 전`;
  if (days < 30) return `${Math.floor(days / 7)}주 전`;
  if (days < 365) return `${Math.floor(days / 30)}개월 전`;
  return `${Math.floor(days / 365)}년 전`;
}

// 통계
const totalDrugs = drugs.length;
const withImageCount = drugs.filter((d) => d.itemImage || pillMap.get(d.itemSeq)?.ITEM_IMAGE).length;
const totalIngredients = new Set(
  drugs.flatMap((d) => permitMap.get(d.itemSeq)?.ITEM_INGR_NAME?.split('/').map((s) => s.trim()).filter(Boolean) ?? [])
).size;
---
<Layout title="홈" description="식약처 공식 데이터 기반 의약품 정보 — 처방분석·부작용 역검색·임부안전 도구 7종">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">FOOD &middot; DRUG &middot; COSMETICS &middot; MEDICAL DEVICE</p>
      <h1>식약처 데이터, <br />하나의 사전으로</h1>
      <p class="lead">의약품 {totalDrugs.toLocaleString()}종부터 화장품·의료기기·건강기능식품·한약·회수정보까지 — 식품의약품안전처 공식 데이터를 도구·검색·비교로 통합 제공.</p>

      <form action="/search" method="get" class="hero-search">
        <input type="search" name="q" placeholder="약 이름·성분·증상으로 검색" autocomplete="off" />
        <button type="submit" aria-label="검색">검색</button>
      </form>

      <div class="hero-stats">
        <div><strong>{totalDrugs.toLocaleString()}</strong><span>의약품</span></div>
        <div><strong>{totalIngredients.toLocaleString()}</strong><span>성분</span></div>
        <div><strong>9+</strong><span>전용 도구</span></div>
        <div><strong>5</strong><span>카테고리 추가중</span></div>
      </div>
    </div>
    <FreshBadge />
  </section>

  <section class="tool-section">
    <div class="section-head">
      <h2>전용 도구</h2>
      <span class="section-sub">AI 가 못 대체하는 정확 데이터·인터랙티브</span>
    </div>
    <div class="tools-grid">
      <a href="/처방분석" class="tool-card tool-feature">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11H5a2 2 0 0 0-2 2v7"/><path d="M9 7H5a2 2 0 0 0-2 2v2"/><circle cx="14" cy="11" r="6"/><path d="M14 11v3"/><path d="M14 8h.01"/></svg>
        </div>
        <strong>처방전 분석</strong>
        <p>여러 약을 한 번에 입력하면 식약처 DUR 80만건 데이터에서 병용금기·상호작용 자동 검사</p>
        <span class="tool-badge">대표 도구</span>
      </a>
      <a href="/부작용검색" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><path d="M11 8v3M11 14h.01"/></svg>
        </div>
        <strong>부작용 역검색</strong>
        <p>의심 증상으로 부작용 등록된 약 찾기</p>
      </a>
      <a href="/모양" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>
        </div>
        <strong>알약 식별</strong>
        <p>모양·색·식별표기로 처방받은 약 찾기</p>
      </a>
      <a href="/비교" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/></svg>
        </div>
        <strong>약 비교</strong>
        <p>두 의약품 효능·부작용·성분 sideway 비교</p>
      </a>
      <a href="/임부안전" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a9 9 0 0 0 0-18 9 9 0 0 0 0 18z"/><circle cx="12" cy="11" r="3"/></svg>
        </div>
        <strong>임부 금기</strong>
        <p>임신·수유 중 절대 금기 약</p>
      </a>
      <a href="/노인주의" class="tool-card">
        <div class="tool-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <strong>노인 주의</strong>
        <p>고령자 신중 복용 의약품</p>
      </a>
    </div>
  </section>

  <AdSlot slot="9123450001" format="auto" />

  <section class="content-section">
    <div class="section-head">
      <h2>의약품 카테고리</h2>
      <span class="section-sub">10,000+ 페이지 의약품 사전</span>
    </div>
    <div class="cat-grid">
      <a href="/search" class="cat-card"><strong>이름으로</strong><span>약 4,757종 검색</span></a>
      <a href="/증상" class="cat-card"><strong>증상별</strong><span>감기·두통·소화 등 20개</span></a>
      <a href="/성분" class="cat-card"><strong>성분별</strong><span>주성분으로 묶음</span></a>
      <a href="/분류" class="cat-card"><strong>약효 분류</strong><span>식약처 표준 분류</span></a>
      <a href="/제약사" class="cat-card"><strong>제약사별</strong><span>제조사로 검색</span></a>
      <a href="/q" class="cat-card"><strong>Q&A</strong><span>자주 묻는 질문 30+</span></a>
    </div>
  </section>

  <section class="content-section">
    <div class="section-head">
      <h2>다른 식약처 카테고리</h2>
      <span class="section-sub">의약품 외 4개 분야 통합</span>
    </div>
    <div class="cat-grid cat-new">
      <a href="/화장품" class="cat-card cat-new-item">
        <strong>화장품</strong><span>기능성·성분·규제정보</span>
      </a>
      <a href="/의료기기" class="cat-card cat-new-item">
        <strong>의료기기</strong><span>품목·허가·등급</span>
      </a>
      <a href="/건기식" class="cat-card cat-new-item">
        <strong>건강기능식품</strong><span>품목·영양·기능성</span>
      </a>
      <a href="/한약" class="cat-card cat-new-item">
        <strong>한약(생약)</strong><span>약재·기원·효능</span>
      </a>
      <a href="/회수" class="cat-card cat-new-item cat-fresh">
        <strong>회수·판매중지</strong><span>식품·의약품 시기성</span>
      </a>
    </div>
  </section>

  <section class="content-section">
    <div class="section-head">
      <h2>최근 허가 의약품</h2>
      <a href="/search" class="see-more">전체 보기 →</a>
    </div>
    {recent.length > 0 ? (
      <ul class="drug-grid">
        {recent.map((d) => (
          <li>
            <a href={`/drug/${d.itemSeq}`} class="drug-card">
              {d._date && <span class="drug-relative">{relativeDate(d._date)}</span>}
              <span class="drug-name">{d.itemName}</span>
              <span class="drug-meta">
                {d.entpName && <span class="drug-entp">{d.entpName}</span>}
                {d._date && <span class="drug-date">{fmtDate(d._date)} 허가</span>}
              </span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">데이터를 불러오는 중입니다.</p>
    )}
  </section>

  <TrustBox />
</Layout>

<style>
  .hero {
    position: relative; overflow: hidden;
    padding: 64px 32px 48px;
    border-radius: 16px;
    margin-bottom: 24px;
    color: #fff;
    background:
      radial-gradient(circle at 85% 15%, rgba(180,83,9,0.25), transparent 50%),
      radial-gradient(circle at 15% 85%, rgba(2,132,199,0.15), transparent 40%),
      linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
    box-shadow: 0 20px 50px rgba(15,23,42,0.25);
  }
  .hero::before {
    content: ''; position: absolute; inset: 0; opacity: 0.06;
    background-image:
      linear-gradient(rgba(255,255,255,0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.4) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }
  .hero-content { position: relative; max-width: 720px; }
  .eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    color: var(--accent-light); margin: 0 0 16px;
  }
  .hero h1 {
    font-family: var(--serif); font-weight: 900;
    font-size: 46px; line-height: 1.15; margin: 0 0 18px;
    letter-spacing: -0.025em; color: #fff;
  }
  .hero .lead {
    font-size: 16px; opacity: 0.88; line-height: 1.7;
    margin: 0 0 28px; max-width: 580px;
  }
  .hero-search {
    display: flex; max-width: 560px; gap: 0;
    background: #fff; border-radius: 10px; overflow: hidden;
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
    margin-bottom: 36px;
  }
  .hero-search input {
    flex: 1; padding: 16px 20px; border: 0; font-size: 15px;
    font-family: var(--sans); color: var(--text);
  }
  .hero-search input:focus { outline: none; }
  .hero-search button {
    padding: 16px 32px; border: 0; cursor: pointer;
    background: var(--accent); color: #fff;
    font-weight: 800; font-size: 14px; letter-spacing: -0.005em;
    font-family: var(--sans);
  }
  .hero-search button:hover { background: #92400e; }

  .hero-stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
    max-width: 600px;
    background: rgba(0,0,0,0.2); border-radius: 10px;
    padding: 4px; margin-bottom: 18px;
  }
  .hero-stats > div {
    text-align: center; padding: 14px 8px;
    background: rgba(255,255,255,0.05); border-radius: 8px;
  }
  .hero-stats strong {
    display: block; font-family: var(--serif); font-weight: 800;
    font-size: 24px; color: var(--accent-light); line-height: 1;
  }
  .hero-stats span {
    display: block; margin-top: 4px; font-size: 11px;
    color: rgba(255,255,255,0.7); letter-spacing: 0.04em;
  }

  .section-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin: 32px 0 14px; gap: 16px; flex-wrap: wrap;
  }
  .section-head h2 {
    font-family: var(--serif); font-weight: 700;
    font-size: 24px; margin: 0; color: var(--navy-900);
    letter-spacing: -0.015em;
  }
  .section-sub {
    color: var(--text-muted); font-size: 13px;
  }
  .see-more {
    font-size: 13px; color: var(--text-muted); font-weight: 500;
  }
  .see-more:hover { color: var(--accent); }

  .tool-section { background: transparent !important; padding: 0 !important; border: 0 !important; box-shadow: none !important; }
  .tools-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px;
  }
  .tool-card {
    display: flex; flex-direction: column; gap: 6px;
    padding: 20px 22px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: 12px;
    text-decoration: none; color: var(--text);
    transition: all 0.2s ease; position: relative;
  }
  .tool-card:hover {
    border-color: var(--navy-900); transform: translateY(-3px);
    box-shadow: var(--shadow-md); text-decoration: none;
  }
  .tool-icon {
    width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
    background: var(--bg-muted); border-radius: 10px; color: var(--navy-900);
    margin-bottom: 4px;
  }
  .tool-card strong {
    font-family: var(--serif); font-weight: 700;
    color: var(--navy-900); font-size: 18px;
  }
  .tool-card p {
    margin: 0; color: var(--text-muted); font-size: 13px; line-height: 1.5;
  }
  .tool-feature {
    background: linear-gradient(135deg, #0f172a, #1e3a8a);
    border-color: var(--navy-900); color: #fff;
    grid-column: span 2;
  }
  .tool-feature:hover { border-color: var(--accent); transform: translateY(-4px); }
  .tool-feature strong { color: #fff; font-size: 22px; }
  .tool-feature p { color: rgba(255,255,255,0.85); }
  .tool-feature .tool-icon { background: rgba(255,255,255,0.1); color: var(--accent-light); }
  .tool-badge {
    position: absolute; top: 14px; right: 16px;
    padding: 4px 10px; background: var(--accent); color: #fff;
    border-radius: 12px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
  }

  .content-section { background: transparent !important; padding: 0 !important; border: 0 !important; box-shadow: none !important; }
  .cat-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px;
  }
  .cat-card {
    display: flex; flex-direction: column; gap: 2px;
    padding: 16px 18px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: 8px;
    text-decoration: none; color: var(--text); transition: all 0.15s;
  }
  .cat-card:hover { border-color: var(--navy-800); background: #fafaff; text-decoration: none; }
  .cat-card strong { font-family: var(--serif); color: var(--navy-900); font-size: 15px; }
  .cat-card span { color: var(--text-muted); font-size: 12px; }
  .cat-new-item {
    background: linear-gradient(180deg, #fff, #fafaf7);
    border-left: 3px solid var(--accent);
  }
  .cat-new-item:hover { border-left-color: var(--navy-900); }
  .cat-fresh { background: linear-gradient(180deg, #ecfdf5, #fff); border-left-color: #10b981; }

  .drug-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 8px;
  }
  .drug-card {
    display: flex; flex-direction: column; gap: 4px;
    padding: 14px 16px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: 8px;
    text-decoration: none; transition: all 0.15s; height: 100%;
  }
  .drug-card:hover {
    border-color: var(--navy-800); transform: translateY(-2px);
    box-shadow: var(--shadow-sm); text-decoration: none;
  }
  .drug-relative {
    display: inline-block; padding: 2px 8px;
    background: var(--accent); color: #fff;
    border-radius: 10px; font-size: 11px; font-weight: 700;
    width: max-content; margin-bottom: 4px;
  }
  .drug-name {
    color: var(--navy-900); font-weight: 600; font-size: 14px;
    line-height: 1.4; letter-spacing: -0.005em;
  }
  .drug-meta {
    display: flex; justify-content: space-between; align-items: center;
    gap: 8px; font-size: 12px;
  }
  .drug-entp { color: var(--text-muted); }
  .drug-date {
    color: var(--accent); font-weight: 600;
    font-family: "SF Mono", Menlo, monospace; font-size: 11px;
  }
  .muted { color: var(--text-light); font-style: italic; }

  @media (max-width: 700px) {
    .hero { padding: 40px 22px 32px; }
    .hero h1 { font-size: 32px; }
    .hero-search { flex-direction: column; }
    .hero-search button { padding: 14px; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
    .tool-feature { grid-column: auto; }
  }
</style>
