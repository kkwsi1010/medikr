---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { fetchAllOdsnAtent } from '../lib/mfds';

const entries = await fetchAllOdsnAtent().catch(() => []);
type Row = { seq: string; name: string; entp: string; ingredient?: string; reason?: string };
const rows: Row[] = entries.map((e) => ({
  seq: e.ITEM_SEQ, name: e.ITEM_NAME, entp: e.ENTP_NAME,
  ingredient: e.INGR_KOR_NAME, reason: e.PROHBT_CONTENT,
}));
---
<Layout
  title="노인 주의 의약품"
  description={`고령자 복용 시 주의해야 할 의약품 ${rows.length.toLocaleString()}건 — 식약처 DUR 데이터`}
>
  <section class="intro">
    <h2>노인 주의 의약품</h2>
    <p>65세 이상 고령자 복용 시 신중한 사용이 필요한 의약품 <strong>{rows.length.toLocaleString()}건</strong> — 식약처 DUR 노인주의 데이터.</p>
    <p class="warn">노인 분이 복용 중이신 약을 확인하고, 의심 사항은 반드시 처방 의사·약사에게 문의하십시오.</p>
  </section>

  <section class="filter-panel">
    <input type="search" id="os-q" placeholder="약 이름·성분으로 검색" autocomplete="off" />
    <div class="filter-info"><span id="os-count">{rows.length.toLocaleString()}</span> 건 표시</div>
  </section>

  <AdSlot slot="9123456789" format="auto" />

  <ul id="os-list" class="os-list"></ul>

  <script type="application/json" id="os-data" set:html={JSON.stringify(rows)}></script>
  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('os-data').textContent);
      const q = document.getElementById('os-q');
      const list = document.getElementById('os-list');
      const count = document.getElementById('os-count');
      const PER = 50;
      let visible = PER, filtered = DATA, t;
      function filter() {
        const term = q.value.trim().toLowerCase();
        filtered = !term ? DATA : DATA.filter(function(r) {
          return (r.name && r.name.toLowerCase().includes(term)) ||
            (r.ingredient && r.ingredient.toLowerCase().includes(term)) ||
            (r.entp && r.entp.toLowerCase().includes(term));
        });
        visible = PER; count.textContent = filtered.length.toLocaleString(); render();
      }
      function render() {
        const slice = filtered.slice(0, visible);
        if (slice.length === 0) { list.innerHTML = '<li class="empty">검색 결과 없음</li>'; return; }
        list.innerHTML = slice.map(function(r) {
          return '<li><a href="/drug/' + r.seq + '"><strong>' + r.name + '</strong></a>'
            + (r.entp ? '<span class="entp"> ' + r.entp + '</span>' : '')
            + (r.ingredient ? '<div class="ing">성분: ' + r.ingredient + '</div>' : '')
            + (r.reason ? '<div class="reason">' + r.reason + '</div>' : '') + '</li>';
        }).join('');
      }
      q.addEventListener('input', function() { clearTimeout(t); t = setTimeout(filter, 200); });
      window.addEventListener('scroll', function() {
        if (visible >= filtered.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER, filtered.length); render();
        }
      });
      render();
    })();
  `}></script>
</Layout>

<style>
  .intro .warn { background: #fffbeb; border-left: 3px solid var(--accent); padding: 12px 16px; border-radius: 4px; font-size: 14px; margin-top: 10px; color: var(--navy-800); }
  .filter-panel { padding: 16px 22px; }
  #os-q { width: 100%; padding: 11px 14px; font-size: 15px; border: 1px solid var(--border-strong); border-radius: 6px; font-family: var(--sans); }
  #os-q:focus { outline: none; border-color: var(--navy-800); }
  .filter-info { margin-top: 10px; font-size: 13px; color: var(--text-muted); }
  .filter-info #os-count { color: var(--navy-900); font-weight: 700; }
  .os-list { list-style: none; padding: 0; margin: 14px 0; }
  .os-list li { padding: 14px 18px; background: #fff; border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 6px; margin-bottom: 6px; }
  .os-list a { color: var(--navy-900); }
  .os-list .entp { color: var(--text-muted); font-size: 13px; margin-left: 6px; }
  .os-list .ing { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .os-list .reason { font-size: 13px; color: var(--navy-800); margin-top: 6px; font-style: italic; }
  .empty { padding: 30px; text-align: center; color: var(--text-light); font-style: italic; border: 0 !important; background: transparent !important; }
</style>
