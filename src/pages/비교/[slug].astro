---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { prefetchAll, type EasyDrug, type PillIdent, type DrugPermit } from '../../lib/mfds';
import { POPULAR_DRUG_NAMES } from '../../lib/popular-drugs';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  const { drugs, pillMap, permitMap } = await prefetchAll();
  // POPULAR 키워드별로 첫 매칭 약 찾기
  const picks: { kw: string; drug: EasyDrug }[] = [];
  for (const kw of POPULAR_DRUG_NAMES) {
    const found = drugs.find((d) => d.itemName.includes(kw));
    if (found) picks.push({ kw, drug: found });
  }
  // 가능한 모든 쌍 조합 (양방향 1번씩, A != B)
  const paths: Array<{ params: { slug: string }; props: any }> = [];
  for (let i = 0; i < picks.length; i++) {
    for (let j = 0; j < picks.length; j++) {
      if (i === j) continue;
      const a = picks[i], b = picks[j];
      const slug = `${slugify(a.kw)}-vs-${slugify(b.kw)}`;
      paths.push({
        params: { slug },
        props: {
          a: a.drug, b: b.drug, kwA: a.kw, kwB: b.kw,
          pillA: pillMap.get(a.drug.itemSeq), pillB: pillMap.get(b.drug.itemSeq),
          permitA: permitMap.get(a.drug.itemSeq), permitB: permitMap.get(b.drug.itemSeq),
        },
      });
    }
  }
  return paths;
}

interface Props {
  a: EasyDrug; b: EasyDrug; kwA: string; kwB: string;
  pillA: PillIdent | undefined; pillB: PillIdent | undefined;
  permitA: DrugPermit | undefined; permitB: DrugPermit | undefined;
}
const { a, b, kwA, kwB, pillA, pillB, permitA, permitB } = Astro.props;

function row(label: string, va?: string | null, vb?: string | null) {
  return { label, va: va || '—', vb: vb || '—' };
}
const rows = [
  row('주성분', permitA?.ITEM_INGR_NAME, permitB?.ITEM_INGR_NAME),
  row('약효 분류', pillA?.CLASS_NAME, pillB?.CLASS_NAME),
  row('구분', pillA?.ETC_OTC_NAME, pillB?.ETC_OTC_NAME),
  row('제조사', a.entpName, b.entpName),
  row('효능', a.efcyQesitm?.slice(0, 200), b.efcyQesitm?.slice(0, 200)),
  row('사용법', a.useMethodQesitm?.slice(0, 200), b.useMethodQesitm?.slice(0, 200)),
  row('주요 부작용', a.seQesitm?.slice(0, 200), b.seQesitm?.slice(0, 200)),
  row('주의사항', a.atpnQesitm?.slice(0, 200), b.atpnQesitm?.slice(0, 200)),
  row('보관', a.depositMethodQesitm?.slice(0, 100), b.depositMethodQesitm?.slice(0, 100)),
  row('모양', pillA?.DRUG_SHAPE, pillB?.DRUG_SHAPE),
  row('색상', pillA?.COLOR_CLASS1, pillB?.COLOR_CLASS1),
];
---
<Layout
  title={`${kwA} vs ${kwB} 비교`}
  description={`${kwA}과(와) ${kwB} 의 효능·부작용·성분·주의사항 차이를 한눈에 비교`}
>
  <nav class="crumb" aria-label="breadcrumb">
    <a href="/">홈</a> <span>›</span> <a href="/비교">약 비교</a> <span>›</span>
    <span class="cur">{kwA} vs {kwB}</span>
  </nav>

  <h2>{kwA} vs {kwB} 비교</h2>
  <p class="meta">의약품 두 종의 성분·효능·부작용 차이를 식약처 공식 데이터로 비교.</p>

  <AdSlot slot="9789012345" format="auto" />

  <div class="cmp-head">
    <div class="cmp-card">
      <a href={`/drug/${a.itemSeq}`}><strong>{a.itemName}</strong></a>
      <span>{a.entpName}</span>
    </div>
    <div class="vs-mark">VS</div>
    <div class="cmp-card">
      <a href={`/drug/${b.itemSeq}`}><strong>{b.itemName}</strong></a>
      <span>{b.entpName}</span>
    </div>
  </div>

  <table class="cmp-table">
    <thead>
      <tr><th></th><th>{kwA}</th><th>{kwB}</th></tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr><th>{r.label}</th><td>{r.va}</td><td>{r.vb}</td></tr>
      ))}
    </tbody>
  </table>

  <AdSlot slot="9890123456" format="auto" />

  <section>
    <h3>더 비교하기</h3>
    <p>다른 두 약을 직접 선택해서 비교하려면 <a href="/비교">약 비교 도구</a> 를 사용하세요.</p>
  </section>
</Layout>

<style>
  .crumb { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; display: flex; gap: 6px; flex-wrap: wrap; }
  .crumb a { color: var(--text-muted); }
  .crumb .cur { color: var(--navy-900); font-weight: 600; }
  .meta { color: var(--text-muted); }
  .cmp-head {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 14px;
    align-items: center; margin: 18px 0;
  }
  .cmp-card {
    padding: 16px 18px; background: #fff; border: 1px solid var(--border);
    border-radius: 8px; text-align: center;
  }
  .cmp-card strong { display: block; font-size: 17px; color: var(--navy-900); margin-bottom: 4px; }
  .cmp-card span { color: var(--text-muted); font-size: 13px; }
  .vs-mark {
    font-family: var(--serif); font-weight: 900; font-size: 28px;
    color: var(--accent); text-align: center;
  }
  .cmp-table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-sm); }
  .cmp-table thead th { background: var(--navy-900); color: #fff; padding: 12px 14px; font-family: var(--serif); font-weight: 700; }
  .cmp-table tbody th { background: var(--bg-muted); padding: 12px 14px; font-weight: 600; color: var(--text-muted); width: 110px; text-align: left; font-size: 13px; }
  .cmp-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); white-space: pre-wrap; vertical-align: top; line-height: 1.55; }
  @media (max-width: 700px) {
    .cmp-head { grid-template-columns: 1fr; }
    .vs-mark { padding: 8px 0; }
    .cmp-table { font-size: 13px; }
    .cmp-table th, .cmp-table td { padding: 8px 10px; }
    .cmp-table tbody th { width: 80px; }
  }
</style>
