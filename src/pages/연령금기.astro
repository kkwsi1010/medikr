---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { fetchAllAgeTaboos } from '../lib/mfds';

const entries = await fetchAllAgeTaboos().catch(() => []);
type Row = { seq: string; name: string; entp: string; ingredient?: string; reason?: string; age?: string };
const rows: Row[] = entries.map((e) => ({
  seq: e.ITEM_SEQ, name: e.ITEM_NAME, entp: e.ENTP_NAME,
  ingredient: e.INGR_KOR_NAME, reason: e.PROHBT_CONTENT, age: e.AGE_BASE,
}));
---
<Layout
  title="연령 금기 의약품"
  description={`소아·청소년 등 특정 연령대 복용 금지 의약품 ${rows.length.toLocaleString()}건`}
>
  <section class="intro">
    <h2>연령 금기 의약품</h2>
    <p>소아·청소년 등 특정 연령대 복용을 금하는 의약품 <strong>{rows.length.toLocaleString()}건</strong> — 식약처 DUR 연령금기.</p>
    <p class="warn">어린이가 복용 중인 약은 반드시 소아과·약사와 상담하십시오.</p>
  </section>

  <section class="filter-panel">
    <input type="search" id="ag-q" placeholder="약 이름·성분·연령으로 검색" autocomplete="off" />
    <div class="filter-info"><span id="ag-count">{rows.length.toLocaleString()}</span> 건 표시</div>
  </section>

  <AdSlot slot="9234567890" format="auto" />

  <ul id="ag-list" class="ag-list"></ul>

  <script type="application/json" id="ag-data" set:html={JSON.stringify(rows)}></script>
  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('ag-data').textContent);
      const q = document.getElementById('ag-q');
      const list = document.getElementById('ag-list');
      const count = document.getElementById('ag-count');
      const PER = 50;
      let visible = PER, filtered = DATA, t;
      function filter() {
        const term = q.value.trim().toLowerCase();
        filtered = !term ? DATA : DATA.filter(function(r) {
          return (r.name && r.name.toLowerCase().includes(term)) ||
            (r.ingredient && r.ingredient.toLowerCase().includes(term)) ||
            (r.age && r.age.toLowerCase().includes(term));
        });
        visible = PER; count.textContent = filtered.length.toLocaleString(); render();
      }
      function render() {
        const slice = filtered.slice(0, visible);
        if (slice.length === 0) { list.innerHTML = '<li class="empty">검색 결과 없음</li>'; return; }
        list.innerHTML = slice.map(function(r) {
          return '<li><a href="/drug/' + r.seq + '"><strong>' + r.name + '</strong></a>'
            + (r.entp ? '<span class="entp"> ' + r.entp + '</span>' : '')
            + (r.age ? '<div class="age-tag">금기 연령: ' + r.age + '</div>' : '')
            + (r.ingredient ? '<div class="ing">성분: ' + r.ingredient + '</div>' : '')
            + (r.reason ? '<div class="reason">' + r.reason + '</div>' : '') + '</li>';
        }).join('');
      }
      q.addEventListener('input', function() { clearTimeout(t); t = setTimeout(filter, 200); });
      window.addEventListener('scroll', function() {
        if (visible >= filtered.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER, filtered.length); render();
        }
      });
      render();
    })();
  `}></script>
</Layout>

<style>
  .intro .warn { background: #fef2f2; border-left: 3px solid #dc2626; padding: 12px 16px; border-radius: 4px; font-size: 14px; margin-top: 10px; color: var(--navy-800); }
  .filter-panel { padding: 16px 22px; }
  #ag-q { width: 100%; padding: 11px 14px; font-size: 15px; border: 1px solid var(--border-strong); border-radius: 6px; font-family: var(--sans); }
  #ag-q:focus { outline: none; border-color: var(--navy-800); }
  .filter-info { margin-top: 10px; font-size: 13px; color: var(--text-muted); }
  .filter-info #ag-count { color: var(--navy-900); font-weight: 700; }
  .ag-list { list-style: none; padding: 0; margin: 14px 0; }
  .ag-list li { padding: 14px 18px; background: #fff; border: 1px solid var(--border); border-left: 3px solid #dc2626; border-radius: 6px; margin-bottom: 6px; }
  .ag-list a { color: var(--navy-900); }
  .ag-list .entp { color: var(--text-muted); font-size: 13px; margin-left: 6px; }
  .ag-list .age-tag { display: inline-block; background: #fef2f2; color: #dc2626; padding: 2px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; margin-top: 4px; }
  .ag-list .ing { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .ag-list .reason { font-size: 13px; color: var(--navy-800); margin-top: 6px; font-style: italic; }
  .empty { padding: 30px; text-align: center; color: var(--text-light); font-style: italic; border: 0 !important; background: transparent !important; }
</style>
