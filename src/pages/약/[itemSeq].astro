---
import Layout from '../../layouts/Layout.astro';
import {
  listEasyDrugs,
  getPillIdent,
  getDrugPermit,
  getDurTaboos,
  type EasyDrug,
} from '../../lib/mfds';

export async function getStaticPaths() {
  // W3 단계 — 500 페이지. W5: 5,000, W7: e약은요 전체 4,757 + 허가정보 마스터까지.
  // 페이지당 추가로 pill/permit/taboos 3개 API 호출 (Promise.all) → 빌드 ~100s 예상.
  const all: EasyDrug[] = [];
  const PER = 100;
  for (let pageNo = 1; pageNo <= 5; pageNo++) {
    const { items, totalCount } = await listEasyDrugs(pageNo, PER);
    all.push(...items);
    if (items.length < PER || pageNo * PER >= totalCount) break;
  }
  return all.map((drug) => ({
    params: { itemSeq: drug.itemSeq },
    props: { drug },
  }));
}

interface Props { drug: EasyDrug }
const { drug } = Astro.props;
const { itemSeq } = Astro.params;

const [pill, permit, taboos] = await Promise.all([
  getPillIdent(itemSeq!).catch(() => null),
  getDrugPermit(itemSeq!).catch(() => null),
  getDurTaboos(itemSeq!).catch(() => []),
]);

const imageSrc = drug.itemImage || pill?.ITEM_IMAGE;
const metaDesc = (drug.efcyQesitm ?? `${drug.itemName} 의 효능, 부작용, 주의사항 등 식약처 공식 정보`).slice(0, 150);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Drug',
  name: drug.itemName,
  manufacturer: drug.entpName ? { '@type': 'Organization', name: drug.entpName } : undefined,
  description: drug.efcyQesitm,
  image: imageSrc,
  url: new URL(Astro.url.pathname, Astro.site).href,
  activeIngredient: permit?.ITEM_INGR_NAME,
  prescriptionStatus: permit?.SPCLTY_PBLC,
};
---
<Layout title={drug.itemName} description={metaDesc} ogImage={imageSrc}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <h2>{drug.itemName}</h2>
    <p style="color:#555;font-size:14px">
      {drug.entpName} · 품목코드 <code>{drug.itemSeq}</code>
    </p>

    {imageSrc && <img src={imageSrc} alt={`${drug.itemName} 이미지`} loading="lazy" />}

    {pill && (
      <section>
        <h3>외형 정보</h3>
        <dl>
          <dt>모양</dt><dd>{pill.DRUG_SHAPE || '—'}</dd>
          <dt>색상</dt><dd>{[pill.COLOR_CLASS1, pill.COLOR_CLASS2].filter(Boolean).join(', ') || '—'}</dd>
          {(pill.PRINT_FRONT || pill.PRINT_BACK) && (
            <>
              <dt>식별표기</dt>
              <dd>{[pill.PRINT_FRONT, pill.PRINT_BACK].filter(Boolean).join(' / ')}</dd>
            </>
          )}
          {pill.CLASS_NAME && (<><dt>약효 분류</dt><dd>{pill.CLASS_NAME}</dd></>)}
          {pill.ETC_OTC_NAME && (<><dt>구분</dt><dd>{pill.ETC_OTC_NAME}</dd></>)}
          {pill.FORM_CODE_NAME && (<><dt>제형</dt><dd>{pill.FORM_CODE_NAME}</dd></>)}
        </dl>
      </section>
    )}

    {drug.efcyQesitm && (
      <section>
        <h3>효능·효과</h3>
        <p>{drug.efcyQesitm}</p>
      </section>
    )}

    {drug.useMethodQesitm && (
      <section>
        <h3>사용법</h3>
        <p>{drug.useMethodQesitm}</p>
      </section>
    )}

    {drug.atpnWarnQesitm && (
      <section>
        <h3>⚠️ 사전 경고</h3>
        <p>{drug.atpnWarnQesitm}</p>
      </section>
    )}

    {drug.atpnQesitm && (
      <section>
        <h3>주의사항</h3>
        <p>{drug.atpnQesitm}</p>
      </section>
    )}

    {drug.intrcQesitm && (
      <section>
        <h3>상호작용</h3>
        <p>{drug.intrcQesitm}</p>
      </section>
    )}

    {drug.seQesitm && (
      <section>
        <h3>부작용</h3>
        <p>{drug.seQesitm}</p>
      </section>
    )}

    {drug.depositMethodQesitm && (
      <section>
        <h3>보관 방법</h3>
        <p>{drug.depositMethodQesitm}</p>
      </section>
    )}

    {taboos.length > 0 && (
      <section>
        <h3>병용금기 ({taboos.length}건)</h3>
        <ul>
          {taboos.slice(0, 10).map((t) => (
            <li>
              <strong>{t.MIXTURE_ITEM_NAME}</strong>
              {t.PROHBT_CONTENT && <span style="color:#666"> — {t.PROHBT_CONTENT}</span>}
            </li>
          ))}
        </ul>
        {taboos.length > 10 && <p style="color:#777;font-size:13px">외 {taboos.length - 10}건</p>}
      </section>
    )}

    {permit && (
      <section>
        <h3>허가 정보</h3>
        <dl>
          {permit.ITEM_PERMIT_DATE && (<><dt>허가일자</dt><dd>{permit.ITEM_PERMIT_DATE}</dd></>)}
          {permit.SPCLTY_PBLC && (<><dt>구분</dt><dd>{permit.SPCLTY_PBLC}</dd></>)}
          {permit.PRDUCT_TYPE && (<><dt>제품 유형</dt><dd>{permit.PRDUCT_TYPE}</dd></>)}
          {permit.ITEM_INGR_NAME && (<><dt>주성분</dt><dd>{permit.ITEM_INGR_NAME}</dd></>)}
        </dl>
      </section>
    )}
  </article>
</Layout>
