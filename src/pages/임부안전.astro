---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { fetchAllPwnmTaboos } from '../lib/mfds';

const taboos = await fetchAllPwnmTaboos().catch(() => []);
// 약별 그룹화 + 등급별 분류
type Row = { seq: string; name: string; entp: string; level?: string; reason?: string; ingredient?: string };
const rows: Row[] = taboos.map((t) => ({
  seq: t.ITEM_SEQ,
  name: t.ITEM_NAME,
  entp: t.ENTP_NAME,
  level: t.PREGNANCY_LEVEL,
  reason: t.PROHBT_CONTENT,
  ingredient: t.INGR_KOR_NAME,
}));
const byLevel = new Map<string, number>();
for (const r of rows) byLevel.set(r.level || '?', (byLevel.get(r.level || '?') ?? 0) + 1);
---
<Layout
  title="임부·수유부 금기 의약품"
  description={`임신 중 또는 수유 중 복용을 금하는 의약품 ${rows.length.toLocaleString()}종 — 식약처 DUR 데이터`}
>
  <section class="intro">
    <h2>임부·수유부 금기 의약품</h2>
    <p>임신 중 또는 수유 중 복용을 금하는 의약품 <strong>{rows.length.toLocaleString()}건</strong> — 식약처 DUR 임부금기 데이터.</p>
    <p class="warn">의심되는 약을 복용 중이거나 임신 가능성이 있다면 본 검색 결과와 관계없이 즉시 산부인과·약사에게 문의하십시오.</p>
  </section>

  <section class="filter-panel">
    <input type="search" id="pw-q" placeholder="약 이름·성분으로 검색" autocomplete="off" />
    <div class="filter-info">
      <span id="pw-count">{rows.length.toLocaleString()}</span> 건 표시
    </div>
  </section>

  <AdSlot slot="9012345678" format="auto" />

  <ul id="pw-list" class="pw-list"></ul>

  <script type="application/json" id="pw-data" set:html={JSON.stringify(rows)}></script>
  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('pw-data').textContent);
      const q = document.getElementById('pw-q');
      const list = document.getElementById('pw-list');
      const count = document.getElementById('pw-count');
      const PER = 50;
      let visible = PER;
      let filtered = DATA;

      function filter() {
        const term = q.value.trim().toLowerCase();
        filtered = !term ? DATA : DATA.filter(function(r) {
          return (r.name && r.name.toLowerCase().includes(term)) ||
            (r.ingredient && r.ingredient.toLowerCase().includes(term)) ||
            (r.entp && r.entp.toLowerCase().includes(term));
        });
        visible = PER;
        count.textContent = filtered.length.toLocaleString();
        render();
      }
      function render() {
        const slice = filtered.slice(0, visible);
        if (slice.length === 0) {
          list.innerHTML = '<li class="empty">검색 결과 없음</li>';
          return;
        }
        list.innerHTML = slice.map(function(r) {
          return '<li><a href="/drug/' + r.seq + '"><strong>' + r.name + '</strong></a>'
            + (r.entp ? '<span class="entp"> ' + r.entp + '</span>' : '')
            + (r.ingredient ? '<div class="ing">성분: ' + r.ingredient + '</div>' : '')
            + (r.reason ? '<div class="reason">' + r.reason + '</div>' : '')
            + '</li>';
        }).join('');
      }
      let t;
      q.addEventListener('input', function() { clearTimeout(t); t = setTimeout(filter, 200); });
      window.addEventListener('scroll', function() {
        if (visible >= filtered.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER, filtered.length);
          render();
        }
      });
      render();
    })();
  `}></script>
</Layout>

<style>
  .intro .warn { background: #fef2f2; border-left: 3px solid #dc2626; padding: 12px 16px; border-radius: 4px; font-size: 14px; margin-top: 10px; color: var(--navy-800); }
  .filter-panel { padding: 16px 22px; }
  #pw-q { width: 100%; padding: 11px 14px; font-size: 15px; border: 1px solid var(--border-strong); border-radius: 6px; font-family: var(--sans); }
  #pw-q:focus { outline: none; border-color: var(--navy-800); }
  .filter-info { margin-top: 10px; font-size: 13px; color: var(--text-muted); }
  .filter-info #pw-count { color: var(--navy-900); font-weight: 700; }
  .pw-list { list-style: none; padding: 0; margin: 14px 0; }
  .pw-list li { padding: 14px 18px; background: #fff; border: 1px solid var(--border); border-left: 3px solid #dc2626; border-radius: 6px; margin-bottom: 6px; }
  .pw-list a { color: var(--navy-900); }
  .pw-list .entp { color: var(--text-muted); font-size: 13px; margin-left: 6px; }
  .pw-list .ing { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .pw-list .reason { font-size: 13px; color: var(--navy-800); margin-top: 6px; font-style: italic; }
  .empty { padding: 30px; text-align: center; color: var(--text-light); font-style: italic; border: 0 !important; background: transparent !important; }
</style>
