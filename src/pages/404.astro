---
import Layout from '../layouts/Layout.astro';
---
<Layout title="페이지를 찾을 수 없음" description="요청하신 페이지가 존재하지 않습니다">
  <section class="err-section">
    <h1>페이지를 찾을 수 없습니다</h1>
    <p class="err-meta">요청하신 의약품 정보 페이지가 존재하지 않거나 이동되었을 수 있습니다.</p>

    <form action="/search" method="get" class="err-search">
      <input type="search" name="q" placeholder="찾고 싶은 약 이름으로 검색해보세요" autocomplete="off" autofocus />
      <button type="submit">검색</button>
    </form>

    <div class="err-grid">
      <a href="/" class="err-card">
        <strong>홈으로</strong><span>medikr 메인 화면</span>
      </a>
      <a href="/처방분석" class="err-card">
        <strong>처방 분석</strong><span>병용금기 검사</span>
      </a>
      <a href="/부작용검색" class="err-card">
        <strong>부작용 역검색</strong><span>증상 → 의심 약</span>
      </a>
      <a href="/모양" class="err-card">
        <strong>알약 식별</strong><span>모양·색·표기</span>
      </a>
      <a href="/q" class="err-card">
        <strong>Q&A</strong><span>자주 묻는 질문</span>
      </a>
      <a href="/about" class="err-card">
        <strong>사이트 소개</strong><span>데이터 출처</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .err-section { text-align: center; padding: 40px 0; }
  .err-section h1 { font-family: var(--serif); font-size: 32px; margin: 0 0 10px; }
  .err-meta { color: var(--text-muted); margin-bottom: 24px; }
  .err-search { display: flex; gap: 6px; max-width: 480px; margin: 0 auto 24px; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-md); }
  .err-search input { flex: 1; padding: 13px 16px; border: 0; font-size: 15px; font-family: var(--sans); }
  .err-search input:focus { outline: none; }
  .err-search button { padding: 13px 24px; background: var(--navy-900); color: #fff; border: 0; font-weight: 700; cursor: pointer; font-family: var(--sans); }
  .err-search button:hover { background: var(--accent); }
  .err-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px; max-width: 600px; margin: 0 auto;
  }
  .err-card {
    display: flex; flex-direction: column; padding: 16px 14px;
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    text-decoration: none; color: var(--text);
  }
  .err-card:hover { border-color: var(--navy-800); transform: translateY(-2px); text-decoration: none; }
  .err-card strong { font-family: var(--serif); color: var(--navy-900); font-size: 16px; margin-bottom: 2px; }
  .err-card span { color: var(--text-muted); font-size: 12px; }
</style>
