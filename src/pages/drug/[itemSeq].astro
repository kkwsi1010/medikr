---
// SSR 모드: 5만 약 페이지 매 요청 처리, Cloudflare edge 24h 캐시
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getEasyDrug, getPillIdent, getDrugPermit, getDurTaboos } from '../../lib/mfds';

// 빌드 시 생성된 색인 (5만 약) — 같은 성분/분류/제약사 추천 + permit-only 약 fallback
// (색인 파싱은 빠름: search.json 의 3.7MB 색인도 0.6s. 느림의 원인은 식약처 API → middleware 캐시로 해결)
import drugNames from '../../data/drug-names.json';
import permitMetaIdx from '../../data/permit-meta.json';
import ingredientIdx from '../../data/ingredient-idx.json';
import classIdx from '../../data/class-idx.json';
import entpIdx from '../../data/entp-idx.json';

const { itemSeq } = Astro.params;
if (!itemSeq) return Astro.redirect('/search/', 302);

// 색인 lookup 먼저 — 식약처 허가 API 가 단건 조회 불가(필터 무시)라 색인이 valid 게이트.
// ★ 색인(43k valid 약)에 없으면 식약처 API 호출 없이 즉시 404 → 잘못된 itemSeq 빠른 응답 + 크롤 예산 절약.
//   (신규 약은 색인 빌드 스냅샷이라 다음 cron 까지 미반영될 수 있으나, 그런 약은 sitemap 에도 없음)
type PermitMeta = { e: string; d: string; i: string; s: string; t: string; no: string };
const _allNames = drugNames as Record<string, string>;
const indexName = _allNames[itemSeq];
if (!indexName) {
  return new Response('Drug not found', { status: 404 });
}

// 색인 통과한 valid 약만 식약처 API 4건 병렬 fetch (e약은요/낱알/허가/병용금기)
const [drugRaw, pill, permit, taboos] = await Promise.all([
  getEasyDrug(itemSeq),
  getPillIdent(itemSeq),
  getDrugPermit(itemSeq),
  getDurTaboos(itemSeq).catch(() => []),
]);

// permit-only 약(e약은요·permit 단건 둘 다 없음)은 색인 meta 로 상세 보강
const meta: PermitMeta | undefined =
  !drugRaw && !permit ? (permitMetaIdx as Record<string, PermitMeta>)[itemSeq] : undefined;

// e약은요 없으면 permit/pill/색인 으로 fallback drug 객체 생성 (효능 등 텍스트는 빈 값)
const drug = drugRaw ?? {
  itemSeq,
  itemName: permit?.ITEM_NAME ?? pill?.ITEM_NAME ?? indexName ?? '의약품',
  entpName: permit?.ENTP_NAME ?? pill?.ENTP_NAME ?? meta?.e ?? '',
  efcyQesitm: undefined,
  useMethodQesitm: undefined,
  atpnQesitm: undefined,
  atpnWarnQesitm: undefined,
  intrcQesitm: undefined,
  seQesitm: undefined,
  depositMethodQesitm: undefined,
  itemImage: undefined,
} as any;

// 허가정보 — 단건 permit 우선, 없으면 색인 meta 로 보강 (permit-only 약도 성분/허가일/구분 표시)
const permitInfo = permit ?? (meta ? {
  ITEM_SEQ: itemSeq,
  ITEM_NAME: indexName ?? drug.itemName,
  ENTP_NAME: meta.e,
  ITEM_PERMIT_DATE: meta.d,
  SPCLTY_PBLC: meta.s,
  PRDUCT_TYPE: meta.t,
  PRDUCT_PRMISN_NO: meta.no,
  ITEM_INGR_NAME: meta.i,
} as typeof permit : null);

// 같은 성분/분류/제약사 약 5개씩 (색인 lookup — 실패해도 graceful)
const _drugNames = (drugNames ?? {}) as Record<string, string>;
const _ingredientIdx = (ingredientIdx ?? {}) as Record<string, string[]>;
const _classIdx = (classIdx ?? {}) as Record<string, string[]>;
const _entpIdx = (entpIdx ?? {}) as Record<string, string[]>;

const sameIngredient: { seq: string; name: string }[] = [];
if (permitInfo?.ITEM_INGR_NAME) {
  const ingredients = permitInfo.ITEM_INGR_NAME.split('/').map((s) => s.trim()).filter(Boolean);
  const seen = new Set<string>();
  for (const ing of ingredients) {
    const list = _ingredientIdx[ing] ?? [];
    for (const seq of list) {
      if (seq === itemSeq || seen.has(seq)) continue;
      const name = _drugNames[seq];
      if (name) { sameIngredient.push({ seq, name }); seen.add(seq); }
      if (sameIngredient.length >= 5) break;
    }
    if (sameIngredient.length >= 5) break;
  }
}

const sameClass: { seq: string; name: string }[] = [];
if (pill?.CLASS_NAME) {
  for (const seq of _classIdx[pill.CLASS_NAME] ?? []) {
    if (seq === itemSeq) continue;
    const name = _drugNames[seq];
    if (name) sameClass.push({ seq, name });
    if (sameClass.length >= 5) break;
  }
}

const sameEntp: { seq: string; name: string }[] = [];
if (drug.entpName) {
  for (const seq of _entpIdx[drug.entpName] ?? []) {
    if (seq === itemSeq) continue;
    const name = _drugNames[seq];
    if (name) sameEntp.push({ seq, name });
    if (sameEntp.length >= 5) break;
  }
}

// Cloudflare edge 캐시 (24h TTL)
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=86400, stale-while-revalidate=604800');

// 약 사진 fallback: e약은요 itemImage > 낱알식별 ITEM_IMAGE > 식약처 nedrug 직접 URL
function buildNedrugImageUrl(itemSeq: string): string {
  // 식약처 의약품안전나라의 일반적인 이미지 패턴 (보장 없음, 일부 약만)
  return `https://nedrug.mfds.go.kr/pbp/cmn/itemImageDownload/${itemSeq}`;
}
const imageSrc = drug.itemImage || pill?.ITEM_IMAGE;
const fallbackImageSrc = !imageSrc ? buildNedrugImageUrl(drug.itemSeq) : null;
// 식약처 텍스트 정리 — \n\n+ → \n (빈 줄 제거), \xa0 → 공백, trim
function compact(text: string): string {
  return text
    .replace(/ /g, ' ')
    .replace(/\r\n/g, '\n')
    .replace(/[ \t]+\n/g, '\n')
    .replace(/\n{2,}/g, '\n')
    .trim();
}
const metaDesc = (drug.efcyQesitm ?? `${drug.itemName} 의 효능, 부작용, 주의사항 등 식약처 공식 정보`).slice(0, 150);

// canonical 정규화 — Layout 과 동일하게 trailing slash. sitemap(/drug/xxx/) 과 일치.
const canonicalUrl = `https://medikr.kr/drug/${itemSeq}/`;

const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://medikr.kr/' },
    { '@type': 'ListItem', position: 2, name: '의약품', item: 'https://medikr.kr/search/' },
    { '@type': 'ListItem', position: 3, name: drug.itemName, item: canonicalUrl },
  ],
};
// Article schema — 의약품 정보 페이지 (Drug schema 는 Google 이 Product snippet 처리
// → offers/review/aggregateRating 필수, medikr 는 판매/리뷰 X → Article 로 변경)
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: drug.itemName,
  description: drug.efcyQesitm ?? metaDesc,
  image: imageSrc ? [imageSrc] : undefined,
  author: { '@type': 'Organization', name: 'medikr' },
  publisher: {
    '@type': 'Organization',
    name: 'medikr',
    url: 'https://medikr.kr/',
  },
  mainEntityOfPage: canonicalUrl,
  about: {
    '@type': 'MedicalEntity',
    name: drug.itemName,
    ...(permitInfo?.ITEM_INGR_NAME && { code: { '@type': 'MedicalCode', code: permitInfo.ITEM_INGR_NAME } }),
  },
};
---
<Layout title={drug.itemName} description={metaDesc} ogImage={imageSrc}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />

  <nav class="crumb" aria-label="breadcrumb">
    <a href="/">홈</a>
    <span>›</span>
    <a href="/search/">의약품</a>
    <span>›</span>
    <span class="cur">{drug.itemName}</span>
  </nav>

  <article>
    <h2>{drug.itemName}</h2>
    {permit?.ITEM_ENG_NAME && (
      <p class="eng-name" style="color:var(--text-muted);font-size:14px;font-style:italic;margin:-6px 0 4px">
        {permit.ITEM_ENG_NAME}
      </p>
    )}
    <p style="color:var(--text-muted);font-size:14px">
      {drug.entpName} · 품목코드 <code>{drug.itemSeq}</code>
      {permitInfo?.PRDUCT_PRMISN_NO && <> · 허가번호 <code>{permitInfo.PRDUCT_PRMISN_NO}</code></>}
    </p>

    <div class="action-row">
      <FavoriteButton itemSeq={drug.itemSeq} itemName={drug.itemName} />
    </div>

    {imageSrc ? (
      <img src={imageSrc} alt={`${drug.itemName} 이미지`} loading="lazy" class="drug-photo" />
    ) : fallbackImageSrc ? (
      <img
        src={fallbackImageSrc}
        alt={`${drug.itemName} 이미지`}
        loading="lazy"
        class="drug-photo"
        onerror="this.style.display='none'"
      />
    ) : null}

    <AdSlot slot="1234567890" format="auto" />

    {pill && (
      <section>
        <h3>외형 정보</h3>
        <dl>
          <dt>모양</dt><dd>{pill.DRUG_SHAPE || '—'}</dd>
          <dt>색상</dt><dd>{[pill.COLOR_CLASS1, pill.COLOR_CLASS2].filter(Boolean).join(', ') || '—'}</dd>
          {(pill.PRINT_FRONT || pill.PRINT_BACK) && (
            <>
              <dt>식별표기</dt>
              <dd>{[pill.PRINT_FRONT, pill.PRINT_BACK].filter(Boolean).join(' / ')}</dd>
            </>
          )}
          {pill.CLASS_NAME && (<><dt>약효 분류</dt><dd>{pill.CLASS_NAME}</dd></>)}
          {pill.ETC_OTC_NAME && (<><dt>구분</dt><dd>{pill.ETC_OTC_NAME}</dd></>)}
          {pill.FORM_CODE_NAME && (<><dt>제형</dt><dd>{pill.FORM_CODE_NAME}</dd></>)}
        </dl>
      </section>
    )}

    {drug.efcyQesitm && (<section><h3>효능·효과</h3><p>{compact(drug.efcyQesitm)}</p></section>)}
    {drug.useMethodQesitm && (<section><h3>사용법</h3><p>{compact(drug.useMethodQesitm)}</p></section>)}
    {drug.atpnWarnQesitm && (<section><h3>사전 경고</h3><p>{compact(drug.atpnWarnQesitm)}</p></section>)}
    {drug.atpnQesitm && (<section><h3>주의사항</h3><p>{compact(drug.atpnQesitm)}</p></section>)}
    {drug.intrcQesitm && (<section><h3>상호작용</h3><p>{compact(drug.intrcQesitm)}</p></section>)}

    <AdSlot slot="9223450002" format="auto" />

    {drug.seQesitm && (<section><h3>부작용</h3><p>{compact(drug.seQesitm)}</p></section>)}
    {drug.depositMethodQesitm && (<section><h3>보관 방법</h3><p>{compact(drug.depositMethodQesitm)}</p></section>)}

    <AdSlot slot="2345678901" format="auto" />

    {taboos.length > 0 && (
      <section>
        <h3>병용금기 ({taboos.length}건)</h3>
        <ul>
          {taboos.slice(0, 10).map((t) => (
            <li>
              <strong>{t.MIXTURE_ITEM_NAME}</strong>
              {t.PROHBT_CONTENT && <span style="color:var(--text-muted)"> — {t.PROHBT_CONTENT}</span>}
            </li>
          ))}
        </ul>
        {taboos.length > 10 && <p style="color:var(--text-muted);font-size:13px">외 {taboos.length - 10}건</p>}
      </section>
    )}

    {permitInfo && (
      <section>
        <h3>허가 정보</h3>
        <dl>
          {permitInfo.ITEM_PERMIT_DATE && (<><dt>허가일자</dt><dd>{permitInfo.ITEM_PERMIT_DATE}</dd></>)}
          {permitInfo.SPCLTY_PBLC && (<><dt>구분</dt><dd>{permitInfo.SPCLTY_PBLC}</dd></>)}
          {permitInfo.PRDUCT_TYPE && (<><dt>제품 유형</dt><dd>{permitInfo.PRDUCT_TYPE}</dd></>)}
          {permitInfo.ITEM_INGR_NAME && (<><dt>주성분</dt><dd>{permitInfo.ITEM_INGR_NAME}</dd></>)}
        </dl>
      </section>
    )}

    <ShareButtons title={drug.itemName} url={new URL(Astro.url.pathname, Astro.site).href} />

    {(sameIngredient.length > 0 || sameClass.length > 0 || sameEntp.length > 0) && (
      <section class="related-section">
        <h3>관련 의약품</h3>
        {sameIngredient.length > 0 && (
          <div class="rel-block">
            <h4>같은 성분 의약품</h4>
            <ul class="rel-list">
              {sameIngredient.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
        {sameClass.length > 0 && (
          <div class="rel-block">
            <h4>같은 약효 분류</h4>
            <ul class="rel-list">
              {sameClass.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
        {sameEntp.length > 0 && (
          <div class="rel-block">
            <h4>{drug.entpName} 의 다른 의약품</h4>
            <ul class="rel-list">
              {sameEntp.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}
  </article>
</Layout>

<style>
  .crumb {
    font-size: 13px; color: var(--text-muted); margin-bottom: 12px;
    display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
  }
  .crumb a { color: var(--text-muted); }
  .crumb a:hover { color: var(--navy-900); }
  .crumb .cur { color: var(--navy-900); font-weight: 600; }
  .action-row { margin: 12px 0; display: flex; gap: 8px; flex-wrap: wrap; }
  .link-row { margin-top: 12px; }
  .link-row a {
    display: inline-block; padding: 8px 14px; background: var(--navy-900);
    color: #fff; border-radius: 6px; font-size: 13px; font-weight: 600;
  }
  .link-row a:hover { background: var(--accent); color: #fff; text-decoration: none; }
  .related-section { background: var(--bg-muted) !important; }
  .rel-block { margin-bottom: 18px; }
  .rel-block:last-child { margin-bottom: 0; }
  .rel-block h4 {
    font-size: 14px; font-weight: 700; color: var(--text-muted);
    margin: 0 0 8px; letter-spacing: 0.02em;
  }
  .rel-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 4px;
  }
  .rel-list li {
    padding: 8px 12px; background: #fff; border: 1px solid var(--border);
    border-radius: 6px; font-size: 13px;
  }
  .rel-list a { color: var(--navy-900); font-weight: 500; }
  .qa-match { background: #fffbeb !important; border-color: var(--accent-light) !important; }
  .qa-match h3 { color: var(--navy-900); }
  .qa-list { list-style: none; padding: 0; margin: 0; }
  .qa-list li { padding: 12px 14px; background: #fff; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 6px; }
  .qa-list a { color: var(--navy-900); }
  .qa-list strong { font-weight: 600; font-size: 14px; }
  .qa-list p { margin: 4px 0 0; color: var(--text-muted); font-size: 13px; line-height: 1.5; }
</style>
