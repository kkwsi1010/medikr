---
// SSR 모드: 5만 약 페이지 매 요청 처리, Cloudflare edge 24h 캐시
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import CoupangSlot from '../../components/CoupangSlot.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getEasyDrug, getPillIdent, getDrugPermit } from '../../lib/mfds';
// 성분 관련약 색인 (작음 0.4MB). 이름/상세/업체·분류 관련약은 D1(tb_drug_cache)에서 조회.
import ingredientIdx from '../../data/ingredient-idx.json';

const { itemSeq } = Astro.params;
if (!itemSeq) return Astro.redirect('/search/', 302);

const env = (Astro.locals as any).runtime?.env;
const DB = env?.DB;

// 약 상세 — D1 조회(ms). 식약처 API(3-7s)를 빌드 시 적재한 tb_drug_cache 로 대체.
let row: any = null;
let dbError = false;
if (DB) {
  try {
    row = await DB.prepare('SELECT * FROM tb_drug_cache WHERE item_seq = ?').bind(itemSeq).first();
  } catch { dbError = true; }
}
// D1 정상인데 row 없음 = 잘못된 itemSeq → 즉시 404 (D1 은 INSERT OR REPLACE 라 항상 데이터 보유).
// D1 에러 또는 로컬(바인딩 없음)일 때만 식약처 API fallback (안전망).
if (!row && DB && !dbError) {
  return new Response('Drug not found', { status: 404 });
}
if (!row) {
  const [d, p, pm] = await Promise.all([
    getEasyDrug(itemSeq), getPillIdent(itemSeq), getDrugPermit(itemSeq),
  ]);
  if (!d && !p && !pm) return new Response('Drug not found', { status: 404 });
  row = {
    item_seq: itemSeq,
    item_name: d?.itemName ?? pm?.ITEM_NAME ?? p?.ITEM_NAME ?? '의약품',
    entp_name: d?.entpName ?? pm?.ENTP_NAME ?? p?.ENTP_NAME ?? '',
    eng_name: pm?.ITEM_ENG_NAME ?? null,
    efcy: d?.efcyQesitm ?? null, use_method: d?.useMethodQesitm ?? null,
    atpn_warn: d?.atpnWarnQesitm ?? null, atpn: d?.atpnQesitm ?? null,
    intrc: d?.intrcQesitm ?? null, se: d?.seQesitm ?? null, deposit: d?.depositMethodQesitm ?? null,
    item_image: d?.itemImage ?? null,
    shape: p?.DRUG_SHAPE ?? null,
    color: [p?.COLOR_CLASS1, p?.COLOR_CLASS2].filter(Boolean).join(', ') || null,
    print_mark: [p?.PRINT_FRONT, p?.PRINT_BACK].filter(Boolean).join(' / ') || null,
    class_name: p?.CLASS_NAME ?? null, otc: p?.ETC_OTC_NAME ?? null, form: p?.FORM_CODE_NAME ?? null,
    pill_image: p?.ITEM_IMAGE ?? null,
    permit_date: pm?.ITEM_PERMIT_DATE ?? null, spclty: pm?.SPCLTY_PBLC ?? null,
    prdct_type: pm?.PRDUCT_TYPE ?? null, prmisn_no: pm?.PRDUCT_PRMISN_NO ?? null, ingr_name: pm?.ITEM_INGR_NAME ?? null,
  };
}

// JSX 호환 — 기존 drug / pill / permitInfo 형태로 매핑
const drug = {
  itemSeq, itemName: row.item_name, entpName: row.entp_name ?? '',
  efcyQesitm: row.efcy, useMethodQesitm: row.use_method, atpnWarnQesitm: row.atpn_warn,
  atpnQesitm: row.atpn, intrcQesitm: row.intrc, seQesitm: row.se, depositMethodQesitm: row.deposit,
  itemImage: row.item_image,
} as any;
const pill = (row.shape || row.color || row.print_mark || row.class_name || row.otc || row.form) ? {
  DRUG_SHAPE: row.shape, COLOR_CLASS1: row.color, COLOR_CLASS2: undefined,
  PRINT_FRONT: row.print_mark, PRINT_BACK: undefined,
  CLASS_NAME: row.class_name, ETC_OTC_NAME: row.otc, FORM_CODE_NAME: row.form, ITEM_IMAGE: row.pill_image,
} as any : null;
const permitInfo = (row.permit_date || row.spclty || row.ingr_name || row.prmisn_no || row.prdct_type) ? {
  ITEM_PERMIT_DATE: row.permit_date, SPCLTY_PBLC: row.spclty, PRDUCT_TYPE: row.prdct_type,
  PRDUCT_PRMISN_NO: row.prmisn_no, ITEM_INGR_NAME: row.ingr_name, ITEM_ENG_NAME: row.eng_name,
} as any : null;

// 병용금기 (DUR) — 식약처 API 가 느려(3-5s) SSR 을 막으므로 client-side(/api/dur.json)로 분리.

// 관련약 — 같은 업체/분류는 D1 인덱스 쿼리, 같은 성분은 색인(seq)+D1 이름
const sameEntp: { seq: string; name: string }[] = [];
const sameClass: { seq: string; name: string }[] = [];
const sameIngredient: { seq: string; name: string }[] = [];
if (DB) {
  try {
    if (row.entp_name) {
      const r = await DB.prepare(
        'SELECT item_seq, item_name FROM tb_drug_cache WHERE entp_name = ? AND item_seq != ? LIMIT 5'
      ).bind(row.entp_name, itemSeq).all();
      for (const x of (r.results ?? []) as any[]) sameEntp.push({ seq: x.item_seq, name: x.item_name });
    }
    if (row.class_name) {
      const r = await DB.prepare(
        'SELECT item_seq, item_name FROM tb_drug_cache WHERE class_name = ? AND item_seq != ? LIMIT 5'
      ).bind(row.class_name, itemSeq).all();
      for (const x of (r.results ?? []) as any[]) sameClass.push({ seq: x.item_seq, name: x.item_name });
    }
    if (row.ingr_name) {
      const _ing = ingredientIdx as Record<string, string[]>;
      const seen = new Set<string>();
      const cand: string[] = [];
      for (const ing of String(row.ingr_name).split('/').map((s) => s.trim()).filter(Boolean)) {
        for (const seq of _ing[ing] ?? []) {
          if (seq === itemSeq || seen.has(seq)) continue;
          seen.add(seq); cand.push(seq);
          if (cand.length >= 5) break;
        }
        if (cand.length >= 5) break;
      }
      if (cand.length) {
        const ph = cand.map(() => '?').join(',');
        const r = await DB.prepare(
          `SELECT item_seq, item_name FROM tb_drug_cache WHERE item_seq IN (${ph})`
        ).bind(...cand).all();
        for (const x of (r.results ?? []) as any[]) sameIngredient.push({ seq: x.item_seq, name: x.item_name });
      }
    }
  } catch { /* 관련약 실패해도 페이지는 정상 */ }
}

// Cloudflare edge 캐시 (24h TTL)
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=86400, stale-while-revalidate=604800');

// 약 사진 fallback: e약은요 itemImage > 낱알식별 ITEM_IMAGE > 식약처 nedrug 직접 URL
function buildNedrugImageUrl(itemSeq: string): string {
  // 식약처 의약품안전나라의 일반적인 이미지 패턴 (보장 없음, 일부 약만)
  return `https://nedrug.mfds.go.kr/pbp/cmn/itemImageDownload/${itemSeq}`;
}
const imageSrc = drug.itemImage || pill?.ITEM_IMAGE;
const fallbackImageSrc = !imageSrc ? buildNedrugImageUrl(drug.itemSeq) : null;
// 식약처 텍스트 정리 — \n\n+ → \n (빈 줄 제거), \xa0 → 공백, trim
function compact(text: string): string {
  return text
    .replace(/ /g, ' ')
    .replace(/\r\n/g, '\n')
    .replace(/[ \t]+\n/g, '\n')
    .replace(/\n{2,}/g, '\n')
    .trim();
}
// 롱테일 검색 매칭 — 약 이름 + 핵심 키워드(효능/용법/부작용)를 앞세우고 효능 본문 이어붙임
const metaDesc = `${drug.itemName} 효능·용법·부작용·주의사항. ${drug.efcyQesitm ?? '식약처 공식 의약품 정보'}`.replace(/\s+/g, ' ').slice(0, 160);

// canonical 정규화 — Layout 과 동일하게 trailing slash. sitemap(/drug/xxx/) 과 일치.
const canonicalUrl = `https://medikr.kr/drug/${itemSeq}/`;

const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://medikr.kr/' },
    { '@type': 'ListItem', position: 2, name: '의약품', item: 'https://medikr.kr/search/' },
    { '@type': 'ListItem', position: 3, name: drug.itemName, item: canonicalUrl },
  ],
};
// Article schema — 의약품 정보 페이지 (Drug schema 는 Google 이 Product snippet 처리
// → offers/review/aggregateRating 필수, medikr 는 판매/리뷰 X → Article 로 변경)
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: drug.itemName,
  description: drug.efcyQesitm ?? metaDesc,
  image: imageSrc ? [imageSrc] : undefined,
  author: { '@type': 'Organization', name: 'medikr' },
  publisher: {
    '@type': 'Organization',
    name: 'medikr',
    url: 'https://medikr.kr/',
  },
  mainEntityOfPage: canonicalUrl,
  about: {
    '@type': 'MedicalEntity',
    name: drug.itemName,
    ...(permitInfo?.ITEM_INGR_NAME && { code: { '@type': 'MedicalCode', code: permitInfo.ITEM_INGR_NAME } }),
  },
};
---
<Layout title={`${drug.itemName} 효능·부작용·용법`} description={metaDesc} ogImage={imageSrc}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbList)} />

  <nav class="crumb" aria-label="breadcrumb">
    <a href="/">홈</a>
    <span>›</span>
    <a href="/search/">의약품</a>
    <span>›</span>
    <span class="cur">{drug.itemName}</span>
  </nav>

  <article>
    <h1>{drug.itemName}</h1>
    {permitInfo?.ITEM_ENG_NAME && (
      <p class="eng-name" style="color:var(--text-muted);font-size:14px;font-style:italic;margin:-6px 0 4px">
        {permitInfo.ITEM_ENG_NAME}
      </p>
    )}
    <p style="color:var(--text-muted);font-size:14px">
      {drug.entpName} · 품목코드 <code>{drug.itemSeq}</code>
      {permitInfo?.PRDUCT_PRMISN_NO && <> · 허가번호 <code>{permitInfo.PRDUCT_PRMISN_NO}</code></>}
    </p>

    <div class="action-row">
      <FavoriteButton itemSeq={drug.itemSeq} itemName={drug.itemName} />
    </div>

    {imageSrc ? (
      <img src={imageSrc} alt={`${drug.itemName} 이미지`} loading="lazy" class="drug-photo" />
    ) : fallbackImageSrc ? (
      <img
        src={fallbackImageSrc}
        alt={`${drug.itemName} 이미지`}
        loading="lazy"
        class="drug-photo"
        onerror="this.style.display='none'"
      />
    ) : null}

    <AdSlot slot="1234567890" format="auto" />

    {pill && (
      <section>
        <h3>외형 정보</h3>
        <dl>
          <dt>모양</dt><dd>{pill.DRUG_SHAPE || '—'}</dd>
          <dt>색상</dt><dd>{[pill.COLOR_CLASS1, pill.COLOR_CLASS2].filter(Boolean).join(', ') || '—'}</dd>
          {(pill.PRINT_FRONT || pill.PRINT_BACK) && (
            <>
              <dt>식별표기</dt>
              <dd>{[pill.PRINT_FRONT, pill.PRINT_BACK].filter(Boolean).join(' / ')}</dd>
            </>
          )}
          {pill.CLASS_NAME && (<><dt>약효 분류</dt><dd>{pill.CLASS_NAME}</dd></>)}
          {pill.ETC_OTC_NAME && (<><dt>구분</dt><dd>{pill.ETC_OTC_NAME}</dd></>)}
          {pill.FORM_CODE_NAME && (<><dt>제형</dt><dd>{pill.FORM_CODE_NAME}</dd></>)}
        </dl>
      </section>
    )}

    {drug.efcyQesitm && (<section><h3>효능·효과</h3><p>{compact(drug.efcyQesitm)}</p></section>)}
    {drug.useMethodQesitm && (<section><h3>사용법</h3><p>{compact(drug.useMethodQesitm)}</p></section>)}
    {drug.atpnWarnQesitm && (<section><h3>사전 경고</h3><p>{compact(drug.atpnWarnQesitm)}</p></section>)}
    {drug.atpnQesitm && (<section><h3>주의사항</h3><p>{compact(drug.atpnQesitm)}</p></section>)}
    {drug.intrcQesitm && (<section><h3>상호작용</h3><p>{compact(drug.intrcQesitm)}</p></section>)}

    <AdSlot slot="9223450002" format="auto" />

    {drug.seQesitm && (<section><h3>부작용</h3><p>{compact(drug.seQesitm)}</p></section>)}
    {drug.depositMethodQesitm && (<section><h3>보관 방법</h3><p>{compact(drug.depositMethodQesitm)}</p></section>)}

    <AdSlot slot="2345678901" format="auto" />

    <section id="taboo-section" style="display:none">
      <h3 id="taboo-title">병용금기</h3>
      <ul id="taboo-list"></ul>
      <p id="taboo-more" style="color:var(--text-muted);font-size:13px"></p>
    </section>
    <script set:html={`
      (function(){
        fetch('/api/dur.json?seq=${itemSeq}').then(function(r){return r.json();}).then(function(d){
          var list = (d && d.taboos) || [];
          if (!list.length) return;
          var sec = document.getElementById('taboo-section');
          var ul = document.getElementById('taboo-list');
          var title = document.getElementById('taboo-title');
          var more = document.getElementById('taboo-more');
          title.textContent = '병용금기 (' + list.length + '건)';
          list.slice(0,10).forEach(function(t){
            var li = document.createElement('li');
            var s = document.createElement('strong');
            s.textContent = t.name || '';
            li.appendChild(s);
            if (t.content) {
              var span = document.createElement('span');
              span.style.color = 'var(--text-muted)';
              span.textContent = ' — ' + t.content;
              li.appendChild(span);
            }
            ul.appendChild(li);
          });
          if (list.length > 10) more.textContent = '외 ' + (list.length - 10) + '건';
          sec.style.display = '';
        }).catch(function(){});
      })();
    `} />

    {permitInfo && (
      <section>
        <h3>허가 정보</h3>
        <dl>
          {permitInfo.ITEM_PERMIT_DATE && (<><dt>허가일자</dt><dd>{permitInfo.ITEM_PERMIT_DATE}</dd></>)}
          {permitInfo.SPCLTY_PBLC && (<><dt>구분</dt><dd>{permitInfo.SPCLTY_PBLC}</dd></>)}
          {permitInfo.PRDUCT_TYPE && (<><dt>제품 유형</dt><dd>{permitInfo.PRDUCT_TYPE}</dd></>)}
          {permitInfo.ITEM_INGR_NAME && (<><dt>주성분</dt><dd>{permitInfo.ITEM_INGR_NAME}</dd></>)}
        </dl>
      </section>
    )}

    <ShareButtons title={drug.itemName} url={new URL(Astro.url.pathname, Astro.site).href} />

    {(sameIngredient.length > 0 || sameClass.length > 0 || sameEntp.length > 0) && (
      <section class="related-section">
        <h3>관련 의약품</h3>
        {sameIngredient.length > 0 && (
          <div class="rel-block">
            <h4>같은 성분 의약품</h4>
            <ul class="rel-list">
              {sameIngredient.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
        {sameClass.length > 0 && (
          <div class="rel-block">
            <h4>같은 약효 분류</h4>
            <ul class="rel-list">
              {sameClass.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
        {sameEntp.length > 0 && (
          <div class="rel-block">
            <h4>{drug.entpName} 의 다른 의약품</h4>
            <ul class="rel-list">
              {sameEntp.map((r) => (
                <li><a href={`/drug/${r.seq}`}>{r.name}</a></li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    <CoupangSlot />
  </article>
</Layout>

<style>
  .crumb {
    font-size: 13px; color: var(--text-muted); margin-bottom: 12px;
    display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
  }
  .crumb a { color: var(--text-muted); }
  .crumb a:hover { color: var(--navy-900); }
  .crumb .cur { color: var(--navy-900); font-weight: 600; }
  .action-row { margin: 12px 0; display: flex; gap: 8px; flex-wrap: wrap; }
  .link-row { margin-top: 12px; }
  .link-row a {
    display: inline-block; padding: 8px 14px; background: var(--navy-900);
    color: #fff; border-radius: 6px; font-size: 13px; font-weight: 600;
  }
  .link-row a:hover { background: var(--accent); color: #fff; text-decoration: none; }
  .related-section { background: var(--bg-muted) !important; }
  .rel-block { margin-bottom: 18px; }
  .rel-block:last-child { margin-bottom: 0; }
  .rel-block h4 {
    font-size: 14px; font-weight: 700; color: var(--text-muted);
    margin: 0 0 8px; letter-spacing: 0.02em;
  }
  .rel-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 4px;
  }
  .rel-list li {
    padding: 8px 12px; background: #fff; border: 1px solid var(--border);
    border-radius: 6px; font-size: 13px;
  }
  .rel-list a { color: var(--navy-900); font-weight: 500; }
  .qa-match { background: #fffbeb !important; border-color: var(--accent-light) !important; }
  .qa-match h3 { color: var(--navy-900); }
  .qa-list { list-style: none; padding: 0; margin: 0; }
  .qa-list li { padding: 12px 14px; background: #fff; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 6px; }
  .qa-list a { color: var(--navy-900); }
  .qa-list strong { font-weight: 600; font-size: 14px; }
  .qa-list p { margin: 4px 0 0; color: var(--text-muted); font-size: 13px; line-height: 1.5; }
</style>
