---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { prefetchAll } from '../lib/mfds';

const { drugs } = await prefetchAll();
const idx = drugs.map((d) => ({ s: d.itemSeq, n: d.itemName, e: d.entpName }));
---
<Layout title="약 비교" description={`두 의약품의 효능·부작용·주의사항을 나란히 비교 (${drugs.length.toLocaleString()}종)`}>
  <section class="intro">
    <h2>약 비교</h2>
    <p>두 의약품의 효능·사용법·부작용·주의사항·성분을 <strong>나란히 비교</strong>해 차이를 한눈에 확인하세요.</p>
  </section>

  <section class="picker">
    <h3>약 두 개 선택</h3>
    <div class="pick-row">
      <div class="pick-slot">
        <label>약 A</label>
        <input type="search" id="cmp-a-q" placeholder="약 이름 검색" autocomplete="off" />
        <div id="cmp-a-sel" class="picked"></div>
        <ul id="cmp-a-sug" class="sug"></ul>
      </div>
      <div class="pick-vs">VS</div>
      <div class="pick-slot">
        <label>약 B</label>
        <input type="search" id="cmp-b-q" placeholder="약 이름 검색" autocomplete="off" />
        <div id="cmp-b-sel" class="picked"></div>
        <ul id="cmp-b-sug" class="sug"></ul>
      </div>
    </div>
    <button id="cmp-go" class="btn-primary" disabled>비교 시작</button>
  </section>

  <AdSlot slot="9345678901" format="auto" />

  <section id="cmp-result" hidden></section>

  <script type="application/json" id="cmp-idx" set:html={JSON.stringify(idx)}></script>
  <script set:html={`
    (function() {
      const INDEX = JSON.parse(document.getElementById('cmp-idx').textContent);
      const sel = { a: null, b: null };

      function bind(side) {
        const q = document.getElementById('cmp-' + side + '-q');
        const sug = document.getElementById('cmp-' + side + '-sug');
        const box = document.getElementById('cmp-' + side + '-sel');
        let t;
        q.addEventListener('input', function(e) {
          clearTimeout(t);
          t = setTimeout(function() {
            const term = e.target.value.trim().toLowerCase();
            if (term.length < 2) { sug.innerHTML = ''; return; }
            const matches = INDEX.filter(function(d) {
              return d.n.toLowerCase().includes(term);
            }).slice(0, 15);
            sug.innerHTML = matches.map(function(d) {
              return '<li data-seq="' + d.s + '"><strong>' + d.n + '</strong><span>' + d.e + '</span></li>';
            }).join('');
          }, 100);
        });
        sug.addEventListener('click', function(e) {
          const li = e.target.closest('li[data-seq]');
          if (!li) return;
          const d = INDEX.find(function(x) { return x.s === li.dataset.seq; });
          sel[side] = d;
          box.innerHTML = '<strong>' + d.n + '</strong> <span>' + d.e + '</span>';
          q.value = ''; sug.innerHTML = '';
          updateBtn();
        });
      }
      bind('a'); bind('b');
      const btn = document.getElementById('cmp-go');
      function updateBtn() {
        btn.disabled = !(sel.a && sel.b && sel.a.s !== sel.b.s);
      }

      btn.addEventListener('click', async function() {
        btn.disabled = true; btn.textContent = '데이터 로딩...';
        const [a, b] = await Promise.all([
          fetch('/api/drug/' + sel.a.s + '.json').then(function(r) { return r.json(); }),
          fetch('/api/drug/' + sel.b.s + '.json').then(function(r) { return r.json(); }),
        ]);
        const result = document.getElementById('cmp-result');
        result.hidden = false;
        function row(label, va, vb) {
          if (!va && !vb) return '';
          return '<tr><th>' + label + '</th>'
            + '<td>' + (va || '<i>—</i>') + '</td>'
            + '<td>' + (vb || '<i>—</i>') + '</td></tr>';
        }
        function img(src, name) {
          return src ? '<img src="' + src + '" alt="' + name + '" loading="lazy" />' : '<div class="no-img">이미지 없음</div>';
        }
        result.innerHTML =
          '<h3>비교 결과</h3>'
          + '<table class="cmp-table">'
          + '<thead><tr><th></th>'
          + '<th><a href="/drug/' + a.s + '">' + a.n + '</a><div class="sub">' + a.e + '</div>' + img(a.image, a.n) + '</th>'
          + '<th><a href="/drug/' + b.s + '">' + b.n + '</a><div class="sub">' + b.e + '</div>' + img(b.image, b.n) + '</th>'
          + '</tr></thead><tbody>'
          + row('효능·효과', a.efcy, b.efcy)
          + row('사용법', a.use, b.use)
          + row('주의사항', a.atpn, b.atpn)
          + row('상호작용', a.intrc, b.intrc)
          + row('부작용', a.se, b.se)
          + row('보관 방법', a.deposit, b.deposit)
          + row('주성분', a.ing, b.ing)
          + row('약효 분류', a.cls, b.cls)
          + row('구분', a.etc, b.etc)
          + row('모양·색', (a.shape + ' ' + a.color).trim(), (b.shape + ' ' + b.color).trim())
          + '</tbody></table>';
        btn.disabled = false; btn.textContent = '다시 비교';
        result.scrollIntoView({ behavior: 'smooth' });
      });
    })();
  `}></script>
</Layout>

<style>
  .picker { padding: 22px 26px; }
  .pick-row {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px;
    align-items: stretch; margin-bottom: 16px;
  }
  .pick-slot { position: relative; }
  .pick-slot label { display: block; font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; letter-spacing: 0.04em; }
  .pick-slot input {
    width: 100%; padding: 11px 14px; font-size: 14px;
    border: 1px solid var(--border-strong); border-radius: 6px; font-family: var(--sans);
  }
  .pick-slot input:focus { outline: none; border-color: var(--navy-800); }
  .picked {
    margin-top: 8px; padding: 10px 14px; background: var(--bg-muted); border-radius: 6px;
    min-height: 42px; font-size: 14px;
  }
  .picked:empty::before { content: '선택된 약 없음'; color: var(--text-light); font-style: italic; font-size: 13px; }
  .picked strong { color: var(--navy-900); }
  .picked span { color: var(--text-muted); font-size: 12px; margin-left: 6px; }
  .pick-vs {
    font-family: var(--serif); font-weight: 900; font-size: 22px;
    color: var(--accent); display: flex; align-items: center; padding-top: 26px;
  }
  .sug {
    list-style: none; padding: 0; margin: 4px 0 0;
    background: #fff; border: 1px solid var(--border); border-radius: 6px;
    max-height: 240px; overflow-y: auto; box-shadow: var(--shadow-md);
    position: absolute; left: 0; right: 0; z-index: 10;
  }
  .sug:empty { display: none; }
  .sug li { padding: 10px 14px; cursor: pointer; display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); font-size: 13px; }
  .sug li:hover { background: #f1f5f9; }
  .sug li strong { color: var(--navy-900); font-weight: 600; }
  .sug li span { color: var(--text-muted); font-size: 12px; }

  .btn-primary {
    width: 100%; padding: 13px; font-size: 15px; font-weight: 700;
    background: var(--navy-900); color: #fff; border: 0; border-radius: 8px;
    cursor: pointer; font-family: var(--sans);
  }
  .btn-primary:hover:not(:disabled) { background: var(--navy-800); }
  .btn-primary:disabled { background: var(--border-strong); color: var(--text-light); cursor: not-allowed; }

  .cmp-table {
    width: 100%; border-collapse: collapse; margin-top: 14px;
    font-size: 14px; background: #fff; border-radius: 8px; overflow: hidden;
  }
  .cmp-table th, .cmp-table td { padding: 14px 16px; vertical-align: top; border-bottom: 1px solid var(--border); text-align: left; }
  .cmp-table thead th { background: var(--bg-muted); font-family: var(--serif); font-weight: 700; font-size: 16px; }
  .cmp-table thead th .sub { color: var(--text-muted); font-size: 12px; font-weight: 400; font-family: var(--sans); margin-top: 2px; }
  .cmp-table thead th img { max-width: 80px; max-height: 60px; display: block; margin-top: 6px; }
  .cmp-table tbody th {
    background: #fafaf7; font-size: 13px; font-weight: 600;
    color: var(--text-muted); width: 110px; white-space: nowrap;
  }
  .cmp-table td { white-space: pre-wrap; line-height: 1.5; }
  .cmp-table i { color: var(--text-light); }
  .no-img { font-size: 11px; color: var(--text-light); }

  @media (max-width: 700px) {
    .pick-row { grid-template-columns: 1fr; }
    .pick-vs { justify-content: center; padding: 0; }
    .cmp-table { font-size: 13px; }
    .cmp-table th, .cmp-table td { padding: 10px 12px; }
    .cmp-table tbody th { width: 80px; }
  }
</style>
