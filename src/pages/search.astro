---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { prefetchAll } from '../lib/mfds';

type SearchItem = { itemSeq: string; itemName: string; entpName: string; ingredient?: string };

const { drugs, permitMap } = await prefetchAll();
const all: SearchItem[] = drugs.map((d) => ({
  itemSeq: d.itemSeq,
  itemName: d.itemName,
  entpName: d.entpName,
  ingredient: permitMap.get(d.itemSeq)?.ITEM_INGR_NAME,
}));
---
<Layout title="의약품 검색" description={`${all.length.toLocaleString()}개 의약품 이름·업체·성분으로 빠른 검색`}>
  <nav class="crumb" aria-label="breadcrumb">
    <a href="/">홈</a> <span>›</span><span class="cur">검색</span>
  </nav>
  <h2>의약품 검색</h2>
  <p class="cnt">총 <strong>{all.length.toLocaleString()}</strong>개 의약품. 이름·업체·성분으로 검색합니다.</p>
  <nav class="cat-tabs" aria-label="카테고리 전환">
    <span class="cat-active">의약품</span>
    <a href="/화장품">화장품</a>
    <a href="/의료기기">의료기기</a>
    <a href="/건기식">건기식</a>
    <a href="/한약">한약</a>
    <a href="/회수">회수</a>
  </nav>

  <div class="search-bar">
    <input type="search" id="q" placeholder="예: 타이레놀, 동화약품, 아세트아미노펜" autocomplete="off" />
  </div>

  <AdSlot slot="9012345678" format="auto" />

  <div id="quick" class="quick-results" hidden></div>
  <ul id="results" class="drug-list"></ul>
  <p id="more" class="more" hidden></p>

  <script type="application/json" id="search-data" set:html={JSON.stringify(all)}></script>

  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('search-data').textContent);
      const q = document.getElementById('q');
      const ul = document.getElementById('results');
      const moreEl = document.getElementById('more');
      const PER = 60;
      let visible = PER;
      let filtered = [];
      let timer;

      // URL ?q=... 자동 검색
      const params = new URLSearchParams(location.search);
      if (params.get('q')) { q.value = params.get('q'); }

      function score(d, term) {
        if (d.itemName.toLowerCase().startsWith(term)) return 100;
        if (d.itemName.toLowerCase().includes(term)) return 50;
        if (d.entpName && d.entpName.toLowerCase().includes(term)) return 20;
        if (d.ingredient && d.ingredient.toLowerCase().includes(term)) return 10;
        return 0;
      }
      function search() {
        const term = q.value.trim().toLowerCase();
        if (term.length < 2) {
          ul.innerHTML = ''; moreEl.hidden = true; return;
        }
        filtered = DATA
          .map(function(d) { return { d: d, s: score(d, term) }; })
          .filter(function(x) { return x.s > 0; })
          .sort(function(a, b) { return b.s - a.s; })
          .map(function(x) { return x.d; });
        visible = PER;
        render();
      }
      function render() {
        if (filtered.length === 0) {
          ul.innerHTML = '<li class="empty">검색 결과 없음</li>';
          moreEl.hidden = true; return;
        }
        const slice = filtered.slice(0, visible);
        ul.innerHTML = slice.map(function(d) {
          return '<li><a href="/drug/' + d.itemSeq + '">' + d.itemName + '</a>'
            + '<span class="entp"> — ' + d.entpName + '</span>'
            + (d.ingredient ? '<div class="ing">성분: ' + d.ingredient + '</div>' : '')
            + '</li>';
        }).join('');
        if (filtered.length > visible) {
          moreEl.textContent = '외 ' + (filtered.length - visible).toLocaleString() + '개 — 스크롤하면 더 표시';
          moreEl.hidden = false;
        } else if (filtered.length > PER) {
          moreEl.textContent = '총 ' + filtered.length.toLocaleString() + '개 표시 완료';
          moreEl.hidden = false;
        } else {
          moreEl.hidden = true;
        }
      }
      q.addEventListener('input', function() { clearTimeout(timer); timer = setTimeout(search, 120); });
      window.addEventListener('scroll', function() {
        if (visible >= filtered.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER, filtered.length);
          render();
        }
      });
      if (q.value) search();
      else q.focus();
    })();
  `}></script>
</Layout>

<style>
  .crumb { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; display: flex; gap: 6px; flex-wrap: wrap; }
  .crumb a { color: var(--text-muted); }
  .crumb .cur { color: var(--navy-900); font-weight: 600; }
  .cnt { color: var(--text-muted); margin-bottom: 14px; }
  .search-bar input {
    width: 100%; padding: 14px 18px; font-size: 16px;
    border: 1px solid var(--border-strong); border-radius: 8px;
    font-family: var(--sans); background: #fff;
  }
  .search-bar input:focus { outline: none; border-color: var(--navy-800); box-shadow: 0 0 0 3px rgba(15,23,42,0.08); }
  .drug-list .ing { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
  .more { text-align: center; color: var(--text-muted); font-size: 13px; padding: 12px; }
  .empty { padding: 30px; text-align: center; color: var(--text-light); font-style: italic; border: 0 !important; background: transparent !important; }
  .cat-tabs {
    display: flex; gap: 4px; margin: 12px 0 18px;
    flex-wrap: wrap; border-bottom: 1px solid var(--border); padding-bottom: 8px;
  }
  .cat-tabs span, .cat-tabs a {
    padding: 6px 14px; border-radius: 6px 6px 0 0; font-size: 13px;
    color: var(--text-muted); text-decoration: none;
  }
  .cat-tabs a:hover { background: var(--bg-muted); color: var(--navy-900); }
  .cat-tabs .cat-active {
    background: var(--navy-900); color: #fff; font-weight: 600;
  }
</style>
