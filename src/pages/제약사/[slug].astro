---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { prefetchAll, type EasyDrug } from '../../lib/mfds';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  const { drugs } = await prefetchAll();
  const map = new Map<string, EasyDrug[]>();
  for (const d of drugs) {
    if (!d.entpName) continue;
    if (!map.has(d.entpName)) map.set(d.entpName, []);
    map.get(d.entpName)!.push(d);
  }
  return Array.from(map.entries())
    .filter(([, list]) => list.length >= 2)
    .map(([entp, list]) => ({
      params: { slug: slugify(entp) },
      props: { entp, drugs: list },
    }));
}

interface Props { entp: string; drugs: EasyDrug[] }
const { entp, drugs } = Astro.props;
---
<Layout title={`${entp} 의약품`} description={`${entp}가 제조한 의약품 ${drugs.length}종`}>
  <h2>{entp}</h2>
  <p style="color:#666">제조 의약품 <strong>{drugs.length}종</strong></p>
  <AdSlot slot="5678901234" format="auto" />
  <ul class="drug-list">
    {drugs.map((d) => (
      <li><a href={`/drug/${d.itemSeq}`}>{d.itemName}</a></li>
    ))}
  </ul>
</Layout>
