---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import FreshBadge from '../components/FreshBadge.astro';
import TrustBox from '../components/TrustBox.astro';
import { prefetchAll } from '../lib/mfds';

const { drugs } = await prefetchAll();
const idx = drugs.map((d) => ({ s: d.itemSeq, n: d.itemName, e: d.entpName }));
---
<Layout
  title="처방전 분석기"
  description={`처방받은 약 ${drugs.length}종 중에서 여러 개를 선택해 병용금기·상호작용 자동 매칭`}
>
  <section class="intro">
    <FreshBadge compact />
    <h2>처방전 분석기</h2>
    <p>처방받은 약을 모두 입력하면 <strong>병용금기</strong> 와 <strong>상호작용 위험</strong> 을 자동으로 검사합니다. 식약처 DUR (의약품안전사용서비스) <strong>80만건</strong> 데이터 기반.</p>
    <p class="warn">정보 제공 목적이며, 의사·약사 상담을 대체하지 않습니다.</p>
  </section>

  <section class="rx-panel">
    <h3>1. 약 추가</h3>
    <div class="search-wrap">
      <input type="search" id="rx-q" placeholder="약 이름 검색 후 선택 (예: 타이레놀)" autocomplete="off" />
      <ul id="rx-suggest" class="suggest"></ul>
    </div>
    <h3>2. 선택된 약 (<span id="rx-count">0</span>개)</h3>
    <ul id="rx-cart" class="cart"></ul>
    <button id="rx-analyze" class="btn-primary" disabled>분석 시작</button>
  </section>

  <AdSlot slot="6789012345" format="auto" />

  <section id="rx-result" class="rx-result" hidden>
    <h3>분석 결과</h3>
    <div id="rx-summary"></div>
    <div id="rx-conflicts"></div>
  </section>

  <TrustBox />

  <script type="application/json" id="rx-index" set:html={JSON.stringify(idx)}></script>

  <script set:html={`
    (function() {
      const INDEX = JSON.parse(document.getElementById('rx-index').textContent);
      const byId = new Map(INDEX.map(d => [d.s, d]));
      const q = document.getElementById('rx-q');
      const sug = document.getElementById('rx-suggest');
      const cart = document.getElementById('rx-cart');
      const count = document.getElementById('rx-count');
      const btn = document.getElementById('rx-analyze');
      const resBox = document.getElementById('rx-result');
      const resSum = document.getElementById('rx-summary');
      const resCon = document.getElementById('rx-conflicts');
      const selected = new Map(); // seq -> drug
      let timer;

      function renderSuggest(term) {
        term = term.trim().toLowerCase();
        if (term.length < 2) { sug.innerHTML = ''; return; }
        const matches = INDEX.filter(d =>
          d.n.toLowerCase().includes(term) || d.e.toLowerCase().includes(term)
        ).filter(d => !selected.has(d.s)).slice(0, 20);
        sug.innerHTML = matches.map(d =>
          '<li data-seq="' + d.s + '"><strong>' + d.n + '</strong><span>' + d.e + '</span></li>'
        ).join('');
      }
      q.addEventListener('input', e => {
        clearTimeout(timer);
        timer = setTimeout(() => renderSuggest(e.target.value), 100);
      });
      sug.addEventListener('click', e => {
        const li = e.target.closest('li[data-seq]');
        if (!li) return;
        const seq = li.dataset.seq;
        const d = byId.get(seq);
        if (!d || selected.has(seq)) return;
        selected.set(seq, d);
        renderCart();
        q.value = ''; sug.innerHTML = ''; q.focus();
      });
      function renderCart() {
        count.textContent = selected.size;
        if (selected.size === 0) {
          cart.innerHTML = '<li class="empty">약을 검색해서 추가하세요</li>';
        } else {
          cart.innerHTML = Array.from(selected.values()).map(d =>
            '<li><span class="cn">' + d.n + '</span><span class="ce">' + d.e + '</span>' +
            '<button data-rm="' + d.s + '" aria-label="삭제">×</button></li>'
          ).join('');
        }
        btn.disabled = selected.size < 2;
      }
      cart.addEventListener('click', e => {
        const b = e.target.closest('button[data-rm]');
        if (!b) return;
        selected.delete(b.dataset.rm);
        renderCart();
      });

      btn.addEventListener('click', async () => {
        btn.disabled = true; btn.textContent = '분석 중...';
        const seqs = Array.from(selected.keys());
        const all = await Promise.all(
          seqs.map(s => fetch('/api/dur/' + s + '.json').then(r => r.ok ? r.json() : []).catch(() => []))
        );
        // taboos[i] = 약 seqs[i] 의 병용금기 목록
        const conflicts = [];
        for (let i = 0; i < seqs.length; i++) {
          for (const t of all[i]) {
            if (selected.has(t.seq)) {
              conflicts.push({
                a: selected.get(seqs[i]).n,
                b: selected.get(t.seq).n,
                reason: t.reason || '병용금기',
                ingredient: t.ingredient,
              });
            }
          }
        }
        resBox.hidden = false;
        if (conflicts.length === 0) {
          resSum.innerHTML = '<div class="ok-box"><strong>입력하신 약들 사이에서 등록된 병용금기 조합이 발견되지 않았습니다.</strong><p>식약처 DUR 데이터 기준입니다. 다른 상호작용·연령금기·임부금기 등은 별도로 확인이 필요할 수 있습니다.</p></div>';
          resCon.innerHTML = '';
        } else {
          // 중복 제거 (A-B == B-A)
          const seen = new Set();
          const unique = [];
          for (const c of conflicts) {
            const key = [c.a, c.b].sort().join('||');
            if (seen.has(key)) continue;
            seen.add(key);
            unique.push(c);
          }
          resSum.innerHTML = '<div class="warn-box"><strong>' + unique.length + '건의 병용금기가 발견되었습니다.</strong><p>아래 조합은 식약처 DUR 데이터에서 함께 복용 금지로 등록된 약들입니다. 즉시 처방한 의사·약사에게 확인하십시오.</p></div>';
          resCon.innerHTML = '<ul class="conflict-list">' + unique.map(c =>
            '<li><div class="cflt-head"><span class="ca">' + c.a + '</span><span class="vs">×</span><span class="cb">' + c.b + '</span></div>' +
            '<div class="cflt-reason">' + (c.reason || '병용금기') + (c.ingredient ? ' (' + c.ingredient + ')' : '') + '</div></li>'
          ).join('') + '</ul>';
        }
        btn.disabled = false; btn.textContent = '다시 분석';
        resBox.scrollIntoView({ behavior: 'smooth' });
      });
      renderCart();
    })();
  `}></script>
</Layout>

<style>
  .intro { margin-bottom: 20px; }
  .intro .warn {
    background: #fef3c7; border-left: 3px solid var(--accent);
    padding: 10px 14px; border-radius: 4px; font-size: 13px; margin-top: 8px;
  }

  .rx-panel { padding: 24px 26px; }
  .search-wrap { position: relative; margin-bottom: 18px; }
  #rx-q {
    width: 100%; padding: 12px 16px; font-size: 15px;
    border: 1px solid var(--border-strong); border-radius: 8px;
    font-family: var(--sans); background: #fff;
  }
  #rx-q:focus { outline: none; border-color: var(--navy-800); box-shadow: 0 0 0 3px rgba(15,23,42,0.08); }

  .suggest {
    list-style: none; padding: 0; margin: 4px 0 0;
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    max-height: 280px; overflow-y: auto; box-shadow: var(--shadow-md);
    position: absolute; left: 0; right: 0; z-index: 10;
  }
  .suggest:empty { display: none; }
  .suggest li {
    padding: 10px 14px; cursor: pointer; display: flex; justify-content: space-between;
    border-bottom: 1px solid var(--border); font-size: 14px;
  }
  .suggest li:last-child { border-bottom: 0; }
  .suggest li:hover { background: #f1f5f9; }
  .suggest li strong { color: var(--navy-900); font-weight: 600; }
  .suggest li span { color: var(--text-muted); font-size: 12px; }

  .cart {
    list-style: none; padding: 0; margin: 0 0 14px;
    min-height: 40px;
  }
  .cart li {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; background: #fff; border: 1px solid var(--border);
    border-radius: 6px; margin-bottom: 4px; font-size: 14px;
  }
  .cart .empty {
    justify-content: center; color: var(--text-light); font-style: italic;
    background: transparent; border: 1px dashed var(--border-strong);
  }
  .cart .cn { font-weight: 600; color: var(--navy-900); flex: 1; }
  .cart .ce { color: var(--text-muted); font-size: 12px; }
  .cart button {
    background: transparent; border: 0; color: var(--text-muted);
    font-size: 20px; cursor: pointer; padding: 0 6px; line-height: 1;
  }
  .cart button:hover { color: #dc2626; }

  .btn-primary {
    width: 100%; padding: 13px; font-size: 15px; font-weight: 700;
    background: var(--navy-900); color: #fff; border: 0; border-radius: 8px;
    cursor: pointer; transition: all 0.15s; font-family: var(--sans);
  }
  .btn-primary:hover:not(:disabled) { background: var(--navy-800); }
  .btn-primary:disabled { background: var(--border-strong); cursor: not-allowed; color: var(--text-light); }

  .rx-result { padding: 24px 26px; }
  .ok-box { background: #ecfdf5; border-left: 3px solid #059669; padding: 14px 18px; border-radius: 4px; }
  .warn-box { background: #fef2f2; border-left: 3px solid #dc2626; padding: 14px 18px; border-radius: 4px; }
  .ok-box strong, .warn-box strong { display: block; font-size: 15px; margin-bottom: 4px; }
  .ok-box p, .warn-box p { margin: 0; font-size: 13px; color: var(--text-muted); }

  .conflict-list { list-style: none; padding: 0; margin: 18px 0 0; }
  .conflict-list li {
    background: #fff; border: 1px solid var(--border); border-radius: 8px;
    padding: 14px 18px; margin-bottom: 8px;
  }
  .cflt-head {
    display: flex; align-items: center; gap: 12px; font-weight: 700;
    font-size: 14px; color: var(--navy-900); margin-bottom: 4px;
  }
  .vs { color: #dc2626; font-weight: 900; font-size: 18px; }
  .cflt-reason { color: var(--text-muted); font-size: 13px; }
</style>
