---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { prefetchAll } from '../../lib/mfds';

type Item = {
  s: string; n: string; e: string;
  image?: string;
  shape?: string;
  color1?: string; color2?: string;
  print?: string;
  cls?: string;
};

const { drugs, pillMap } = await prefetchAll();
const items: Item[] = drugs.map((d) => {
  const p = pillMap.get(d.itemSeq);
  return {
    s: d.itemSeq,
    n: d.itemName,
    e: d.entpName,
    image: d.itemImage || p?.ITEM_IMAGE,
    shape: p?.DRUG_SHAPE,
    color1: p?.COLOR_CLASS1,
    color2: p?.COLOR_CLASS2,
    print: [p?.PRINT_FRONT, p?.PRINT_BACK].filter(Boolean).join(' | ') || undefined,
    cls: p?.CLASS_NAME,
  };
});

const shapes = Array.from(new Set(items.map((i) => i.shape).filter(Boolean) as string[])).sort();
const colors = Array.from(
  new Set(items.flatMap((i) => [i.color1, i.color2]).filter(Boolean) as string[])
).sort();
const withImageCount = items.filter((i) => i.image).length;
---
<Layout title="알약 식별" description={`모양·색·식별표기로 의약품 ${items.length.toLocaleString()}종 검색`}>
  <section class="intro">
    <h2>알약 식별 도구</h2>
    <p>처방받은 약의 이름을 모를 때 <strong>모양·색·식별표기</strong> 로 직접 찾으세요. 식약처 낱알식별 데이터 {items.length.toLocaleString()}종 (이미지 보유 {withImageCount.toLocaleString()}종).</p>
  </section>

  <section class="filter-panel">
    <div class="filter-row">
      <label>
        <span>모양</span>
        <select id="f-shape">
          <option value="">전체</option>
          {shapes.map((s) => <option value={s}>{s}</option>)}
        </select>
      </label>
      <label>
        <span>색상</span>
        <select id="f-color">
          <option value="">전체</option>
          {colors.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex-grow">
        <span>식별표기</span>
        <input type="search" id="f-print" placeholder="예: TY, IDG, 365" autocomplete="off" />
      </label>
      <button id="f-reset" type="button">초기화</button>
    </div>
    <div class="filter-info">
      <span id="f-count">{items.length.toLocaleString()}</span> 종 표시
      <span class="hint">이미지가 있는 약만 보기 <input type="checkbox" id="f-image" /></span>
    </div>
  </section>

  <AdSlot slot="7890123456" format="auto" />

  <div id="pill-grid" class="pill-grid"></div>

  <script type="application/json" id="pill-data" set:html={JSON.stringify(items)}></script>
  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('pill-data').textContent);
      const grid = document.getElementById('pill-grid');
      const fShape = document.getElementById('f-shape');
      const fColor = document.getElementById('f-color');
      const fPrint = document.getElementById('f-print');
      const fImage = document.getElementById('f-image');
      const fReset = document.getElementById('f-reset');
      const fCount = document.getElementById('f-count');
      const PER_PAGE = 60;
      let visible = PER_PAGE;
      let filtered = DATA;

      function applyFilters() {
        const sh = fShape.value;
        const co = fColor.value;
        const pr = fPrint.value.trim().toUpperCase();
        const onlyImg = fImage.checked;
        filtered = DATA.filter(function(d) {
          if (sh && d.shape !== sh) return false;
          if (co && d.color1 !== co && d.color2 !== co) return false;
          if (pr && (!d.print || d.print.toUpperCase().indexOf(pr) === -1)) return false;
          if (onlyImg && !d.image) return false;
          return true;
        });
        visible = PER_PAGE;
        fCount.textContent = filtered.length.toLocaleString();
        render();
      }
      function render() {
        const slice = filtered.slice(0, visible);
        if (slice.length === 0) {
          grid.innerHTML = '<div class="empty">조건에 맞는 약이 없습니다.</div>';
          return;
        }
        grid.innerHTML = slice.map(function(d) {
          const img = d.image
            ? '<img src="' + d.image + '" alt="' + d.n + '" loading="lazy" />'
            : '<div class="no-img">이미지 없음</div>';
          const sub = [d.shape, d.color1, d.print].filter(Boolean).join(' · ');
          return '<a href="/drug/' + d.s + '" class="pill-card">'
            + '<div class="pill-img-wrap">' + img + '</div>'
            + '<div class="pill-name">' + d.n + '</div>'
            + (sub ? '<div class="pill-sub">' + sub + '</div>' : '')
            + '</a>';
        }).join('');
      }
      fShape.addEventListener('change', applyFilters);
      fColor.addEventListener('change', applyFilters);
      fImage.addEventListener('change', applyFilters);
      let t;
      fPrint.addEventListener('input', function() { clearTimeout(t); t = setTimeout(applyFilters, 200); });
      fReset.addEventListener('click', function() {
        fShape.value = ''; fColor.value = ''; fPrint.value = ''; fImage.checked = false;
        applyFilters();
      });
      window.addEventListener('scroll', function() {
        if (visible >= filtered.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER_PAGE, filtered.length);
          render();
        }
      });
      render();
    })();
  `}></script>
</Layout>

<style>
  .intro p { color: var(--text-muted); }
  .filter-panel { padding: 18px 22px; margin-bottom: 14px; }
  .filter-row {
    display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;
  }
  .filter-row label { display: flex; flex-direction: column; gap: 4px; font-size: 12px; color: var(--text-muted); font-weight: 600; }
  .filter-row label.flex-grow { flex: 1; min-width: 180px; }
  .filter-row select, .filter-row input[type=search] {
    padding: 9px 12px; font-size: 14px; border: 1px solid var(--border-strong);
    border-radius: 6px; background: #fff; font-family: var(--sans); min-width: 120px;
  }
  .filter-row input[type=search] { width: 100%; }
  .filter-row select:focus, .filter-row input:focus { outline: none; border-color: var(--navy-800); }
  .filter-row button {
    padding: 9px 16px; border: 1px solid var(--border-strong); background: #fff;
    border-radius: 6px; cursor: pointer; font-size: 13px; font-family: var(--sans);
    color: var(--text-muted); height: 38px;
  }
  .filter-row button:hover { background: var(--bg-muted); color: var(--navy-900); }
  .filter-info {
    margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);
    font-size: 13px; color: var(--text-muted);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }
  .filter-info #f-count { color: var(--navy-900); font-weight: 700; }
  .filter-info .hint { display: flex; align-items: center; gap: 6px; }

  .pill-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px; margin-top: 14px;
  }
  .pill-card {
    display: flex; flex-direction: column; gap: 4px;
    padding: 10px; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 8px; text-decoration: none; color: var(--text);
    transition: all 0.15s;
  }
  .pill-card:hover { border-color: var(--navy-800); transform: translateY(-2px); box-shadow: var(--shadow-sm); text-decoration: none; }
  .pill-img-wrap { background: var(--bg-muted); border-radius: 6px; padding: 8px; min-height: 90px; display: flex; align-items: center; justify-content: center; }
  .pill-img-wrap img { width: 100%; height: 76px; object-fit: contain; max-width: 100%; }
  .no-img { color: var(--text-light); font-size: 11px; font-style: italic; }
  .pill-name { font-size: 13px; font-weight: 600; color: var(--navy-900); line-height: 1.3; }
  .pill-sub { color: var(--text-muted); font-size: 11px; }
  .empty { grid-column: 1/-1; padding: 40px; text-align: center; color: var(--text-light); font-style: italic; }
</style>
