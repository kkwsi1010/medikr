---
import Layout from '../../layouts/Layout.astro';
import { listEasyDrugs } from '../../lib/mfds';

// 모양/색 인덱스 — 빌드 시 모든 약 메타 수집 후 클라이언트 필터
type Item = { itemSeq: string; itemName: string; image?: string };
// W1 라이브: 1,000 약. W5 에서 전체 확장.
const all: Item[] = [];
for (let p = 1; p <= 10; p++) {
  const { items, totalCount } = await listEasyDrugs(p, 100);
  for (const d of items) {
    all.push({ itemSeq: d.itemSeq, itemName: d.itemName, image: d.itemImage });
  }
  if (items.length < 100 || p * 100 >= totalCount) break;
}
---
<Layout title="모양·색으로 찾기" description={`${all.length}개 약 이미지로 알약 식별`}>
  <h2>모양·색으로 찾기</h2>
  <p>약 이미지를 보고 직접 찾기 — 총 {all.length.toLocaleString()}개 의약품</p>
  <p style="color:#666;font-size:14px">처방받은 약 이름을 모를 때 사용하세요. 이름을 안다면 <a href="/search">검색</a>이 더 빠릅니다.</p>

  <div id="pills" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-top:16px"></div>

  <script type="application/json" id="pill-data" set:html={JSON.stringify(all)}></script>
  <script set:html={`
    (function() {
      const DATA = JSON.parse(document.getElementById('pill-data').textContent);
      const container = document.getElementById('pills');
      const PER_PAGE = 60;
      let visible = PER_PAGE;
      function render() {
        const slice = DATA.slice(0, visible);
        container.innerHTML = slice.map(function(d) {
          const img = d.image
            ? '<img src="' + d.image + '" alt="' + d.itemName + '" loading="lazy" style="width:100%;height:80px;object-fit:contain;background:#f5f5f5;border-radius:4px" />'
            : '<div style="height:80px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#aaa;border-radius:4px;font-size:11px">이미지 없음</div>';
          return '<a href="/약/' + d.itemSeq + '" style="display:block;text-decoration:none;color:#222;font-size:12px;text-align:center">'
            + img + '<div style="margin-top:4px;line-height:1.3;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">' + d.itemName + '</div></a>';
        }).join('');
      }
      render();
      window.addEventListener('scroll', function() {
        if (visible >= DATA.length) return;
        if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 500) {
          visible = Math.min(visible + PER_PAGE, DATA.length);
          render();
        }
      });
    })();
  `}></script>
</Layout>
