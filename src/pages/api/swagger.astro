---
// Swagger UI 페이지 — CDN 의 swagger-ui-dist 로딩, /api/openapi.json 표시
const title = 'medikr API — Swagger UI';
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="medikr API Swagger UI — endpoint 6개, 인증키 없음, CORS 전체 허용" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui.css" />
  <style>
    body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
    .topbar {
      background: linear-gradient(135deg, #0f172a, #1e3a8a);
      color: #fff; padding: 16px 32px; display: flex; align-items: center; gap: 20px;
    }
    .topbar a { color: #fbbf24; text-decoration: none; font-weight: 600; }
    .topbar a:hover { text-decoration: underline; }
    .topbar h1 { margin: 0; font-size: 20px; font-weight: 800; }
    .topbar .spacer { flex: 1; }
    .topbar .links { display: flex; gap: 16px; font-size: 14px; }
    #swagger-ui { max-width: 1200px; margin: 0 auto; }
    .swagger-ui .topbar { display: none; }
  </style>
</head>
<body>
  <header class="topbar">
    <h1>medikr API</h1>
    <span style="font-size:13px;opacity:0.8">식약처 데이터 무료 통합 API</span>
    <span class="spacer"></span>
    <div class="links">
      <a href="/api/">문서</a>
      <a href="/api/openapi.json" target="_blank">openapi.json</a>
      <a href="/">medikr.kr</a>
    </div>
  </header>
  <div id="swagger-ui"></div>
  <script src="https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js" crossorigin></script>
  <script>
    window.addEventListener('load', function () {
      window.ui = SwaggerUIBundle({
        url: '/api/openapi.json',
        dom_id: '#swagger-ui',
        deepLinking: true,
        defaultModelsExpandDepth: 1,
        docExpansion: 'list',
        tryItOutEnabled: true,
        syntaxHighlight: { theme: 'monokai' },
      });
    });
  </script>
</body>
</html>
