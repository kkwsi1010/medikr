MFDS_API_KEY=your_public_data_portal_key_here

# 카카오 애드핏 — adfit.kakao.com 에서 사이트/광고단위 등록 후 발급
# 값이 없으면 애드핏 광고는 렌더되지 않음 (화면 변화 없음)
PUBLIC_ADFIT_UNIT=DAN-xxxxxxxxxxxxxxxx

# 쿠팡파트너스 다이내믹 배너 — partners.coupang.com 에서 배너 위젯 생성 시 발급
# 위젯 생성 코드의 id(숫자)와 trackingCode(AFxxxxxxx) 두 값을 각각 넣음
# 둘 다 있어야 배너가 렌더됨 (없으면 화면 변화 없음)
PUBLIC_COUPANG_ID=1234567
PUBLIC_COUPANG_TRACKING=AF0000000
